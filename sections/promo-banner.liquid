{%- style -%}
  #shopify-section-{{ section.id }} {
    /* Colors */
    --promo-bg:      {{ section.settings.bg_color }};
    --promo-eyebrow: {{ section.settings.eyebrow_color }};
    --promo-heading: {{ section.settings.heading_color }};
    --promo-body:    {{ section.settings.body_color }};
    --promo-btn:     {{ section.settings.btn_color }};
    --promo-btn-text:{{ section.settings.btn_text_color }};
    --promo-btn-bc:  {{ section.settings.btn_border_color }};
    /* Eyebrow */
    --promo-eye-font:      {{ section.settings.eye_font }};
    --promo-eye-size:      {{ section.settings.eye_size }}px;
    --promo-eye-weight:    {{ section.settings.eye_weight }};
    --promo-eye-transform: {{ section.settings.eye_transform }};
    --promo-eye-ls:        {{ section.settings.eye_ls | times: 0.1 }}px;
    --promo-eye-lh:        {{ section.settings.eye_lh | divided_by: 10.0 }};
    --promo-eye-style:      {{ section.settings.eye_style }};
    --promo-eye-decoration: {{ section.settings.eye_decoration }};
    /* Heading */
    --promo-head-font:       {{ section.settings.head_font }};
    --promo-head-size:       {{ section.settings.head_size }}px;
    --promo-head-weight:     {{ section.settings.head_weight }};
    --promo-head-transform:  {{ section.settings.head_transform }};
    --promo-head-ls:         {{ section.settings.head_ls | times: 0.1 }}px;
    --promo-head-lh:         {{ section.settings.head_lh | divided_by: 10.0 }};
    --promo-head-style:      {{ section.settings.head_style }};
    --promo-head-decoration: {{ section.settings.head_decoration }};
    /* Body */
    --promo-body-font:       {{ section.settings.body_font }};
    --promo-body-size:       {{ section.settings.body_size }}px;
    --promo-body-weight:     {{ section.settings.body_weight }};
    --promo-body-transform:  {{ section.settings.body_transform }};
    --promo-body-ls:         {{ section.settings.body_ls | times: 0.1 }}px;
    --promo-body-lh:         {{ section.settings.body_lh | divided_by: 10.0 }};
    --promo-body-style:      {{ section.settings.body_style }};
    --promo-body-decoration: {{ section.settings.body_decoration }};
    /* Button */
    --promo-btn-font:       {{ section.settings.btn_font }};
    --promo-btn-size:       {{ section.settings.btn_size }}px;
    --promo-btn-weight:     {{ section.settings.btn_weight }};
    --promo-btn-transform:  {{ section.settings.btn_transform }};
    --promo-btn-ls:         {{ section.settings.btn_ls | times: 0.1 }}px;
    --promo-btn-lh:         {{ section.settings.btn_lh | divided_by: 10.0 }};
    --promo-btn-style:      {{ section.settings.btn_style }};
    --promo-btn-decoration: {{ section.settings.btn_decoration }};
    --promo-btn-pv:         {{ section.settings.btn_pv }}px;
    --promo-btn-ph:         {{ section.settings.btn_ph }}px;
    --promo-btn-radius:     {{ section.settings.btn_radius }}px;
    --promo-btn-bw:         {{ section.settings.btn_border_width }}px;
    --promo-btn-minw:       {{ section.settings.btn_min_width }}px;
    /* Layout */
    --promo-img-maxw:   {{ section.settings.image_max_width }}px;
    --promo-corner-w:   {{ section.settings.corner_width }}px;
    --promo-pt:         {{ section.settings.section_pt }}px;
    --promo-pb:         {{ section.settings.section_pb }}px;
    /* Alignment & Container */
    --promo-align: {{ section.settings.content_align }};
    --promo-maxw:  {{ section.settings.content_max_width }}px;
    --promo-pl:    {{ section.settings.section_pl }}px;
    --promo-pr:    {{ section.settings.section_pr }}px;
    --promo-minh:  {{ section.settings.section_minh }}px;
    --promo-content-items: {% if section.settings.content_align == 'center' %}center{% elsif section.settings.content_align == 'right' %}flex-end{% else %}flex-start{% endif %};
    background-color: var(--promo-bg);
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --promo-eye-size:  {{ section.settings.eye_size_mobile }}px;
      --promo-head-size: {{ section.settings.head_size_mobile }}px;
      --promo-body-size: {{ section.settings.body_size_mobile }}px;
      --promo-btn-size:  {{ section.settings.btn_size_mobile }}px;
      --promo-pt: {{ section.settings.section_pt_mobile }}px;
      --promo-pb: {{ section.settings.section_pb_mobile }}px;
      --promo-pl: {{ section.settings.section_pl_mobile }}px;
      --promo-pr: {{ section.settings.section_pr_mobile }}px;
    }
  }
{%- endstyle -%}

<style>
  .gwmf-promo { position: relative; width: 100%; overflow: visible; }

  .gwmf-promo__waves-clip { position: absolute; inset: 0; overflow: hidden; pointer-events: none; z-index: 1; }
  .gwmf-promo__wave-top, .gwmf-promo__wave-bottom { position: absolute; left: 0; width: 100%; line-height: 0; pointer-events: none; }
  .gwmf-promo__wave-top { top: -1px; }
  .gwmf-promo__wave-bottom { bottom: -1px; }
  .gwmf-promo__wave-top svg, .gwmf-promo__wave-bottom svg { display: block; width: 100%; height: 80px; }

  .gwmf-promo__corner { position: absolute; top: -20px; left: 0; z-index: 10; pointer-events: none; }
  .gwmf-promo__corner img { width: var(--promo-corner-w); height: auto; display: block; }

  .gwmf-promo__inner {
    position: relative; z-index: 3;
    max-width: var(--promo-maxw); margin: 0 auto;
    padding: var(--promo-pt) var(--promo-pr) var(--promo-pb) var(--promo-pl);
    min-height: var(--promo-minh);
    text-align: var(--promo-align);
    display: grid; grid-template-columns: 50% 50%;
    align-items: center; gap: 0;
  }

  .gwmf-promo__content { display: flex; flex-direction: column; align-items: var(--promo-content-items); gap: 20px; padding-right: 32px; text-align: var(--promo-align); }

  .gwmf-promo__eyebrow {
    font-family: var(--promo-eye-font);
    font-size: var(--promo-eye-size);
    font-weight: var(--promo-eye-weight);
    text-transform: var(--promo-eye-transform);
    letter-spacing: var(--promo-eye-ls);
    line-height: var(--promo-eye-lh);
    font-style: var(--promo-eye-style);
    text-decoration: var(--promo-eye-decoration);
    color: var(--promo-eyebrow); margin: 0;
  }

  .gwmf-promo__heading {
    font-family: var(--promo-head-font);
    font-size: var(--promo-head-size);
    font-weight: var(--promo-head-weight);
    text-transform: var(--promo-head-transform);
    letter-spacing: var(--promo-head-ls);
    line-height: var(--promo-head-lh);
    font-style: var(--promo-head-style);
    text-decoration: var(--promo-head-decoration);
    color: var(--promo-heading); margin: 0; white-space: pre-line;
  }

  .gwmf-promo__body {
    font-family: var(--promo-body-font);
    font-size: var(--promo-body-size);
    font-weight: var(--promo-body-weight);
    text-transform: var(--promo-body-transform);
    letter-spacing: var(--promo-body-ls);
    line-height: var(--promo-body-lh);
    font-style: var(--promo-body-style);
    text-decoration: var(--promo-body-decoration);
    color: var(--promo-body); margin: 0; max-width: 480px;
  }

  .gwmf-promo__btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: var(--promo-btn-pv) var(--promo-btn-ph);
    background: var(--promo-btn);
    color: var(--promo-btn-text);
    font-family: var(--promo-btn-font);
    font-size: var(--promo-btn-size);
    font-weight: var(--promo-btn-weight);
    text-transform: var(--promo-btn-transform);
    letter-spacing: var(--promo-btn-ls);
    line-height: var(--promo-btn-lh);
    font-style: var(--promo-btn-style);
    text-decoration: var(--promo-btn-decoration);
    border-radius: var(--promo-btn-radius);
    border: var(--promo-btn-bw) solid var(--promo-btn-bc);
    min-width: var(--promo-btn-minw);
    transition: filter 0.2s, transform 0.15s; margin-top: 4px;
  }

  .gwmf-promo__btn:hover { filter: brightness(1.1); transform: translateY(-2px); }

  .gwmf-promo__image-wrap { display: flex; align-items: flex-end; justify-content: flex-end; height: 100%; }
  .gwmf-promo__image-wrap img { width: 100%; max-width: var(--promo-img-maxw); height: auto; display: block; object-fit: contain; }
  .gwmf-promo__img-placeholder { width: 100%; max-width: var(--promo-img-maxw); aspect-ratio: 16/10; background: rgba(255,255,255,0.08); border-radius: 16px; display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.3); border: 2px dashed rgba(255,255,255,0.2); }

  .gwmf-promo__eyebrow, .gwmf-promo__heading, .gwmf-promo__body, .gwmf-promo__btn, .gwmf-promo__image-wrap { opacity: 0; transition: opacity 0.65s ease, transform 0.65s ease; }
  .gwmf-promo__content > * { transform: translateX(-36px); }
  .gwmf-promo__image-wrap { transform: translateX(36px); }
  .gwmf-promo.is-visible .gwmf-promo__eyebrow { opacity: 1; transform: translateX(0); transition-delay: 0s; }
  .gwmf-promo.is-visible .gwmf-promo__heading { opacity: 1; transform: translateX(0); transition-delay: 0.1s; }
  .gwmf-promo.is-visible .gwmf-promo__body { opacity: 1; transform: translateX(0); transition-delay: 0.2s; }
  .gwmf-promo.is-visible .gwmf-promo__btn { opacity: 1; transform: translateX(0); transition-delay: 0.3s; }
  .gwmf-promo.is-visible .gwmf-promo__image-wrap { opacity: 1; transform: translateX(0); transition-delay: 0.15s; }

  @media screen and (max-width: 989px) {
    .gwmf-promo__inner { grid-template-columns: 1fr; padding: calc(var(--promo-pt)*0.88) calc(var(--promo-pr)*0.75) calc(var(--promo-pb)*0.8) calc(var(--promo-pl)*0.75); gap: 32px; text-align: center; }
    .gwmf-promo__content { align-items: center; padding-right: 0; order: 1; }
    .gwmf-promo__image-wrap { justify-content: center; order: 2; }
    .gwmf-promo__body { max-width: 100%; }
    .gwmf-promo__wave-top svg, .gwmf-promo__wave-bottom svg { height: 56px; }
  }
  @media screen and (max-width: 749px) {
    .gwmf-promo__inner { padding: var(--promo-pt) var(--promo-pr) var(--promo-pb) var(--promo-pl); gap: 24px; }
    .gwmf-promo__btn { width: 100%; max-width: 360px; min-width: unset; }
    .gwmf-promo__wave-top svg, .gwmf-promo__wave-bottom svg { height: 40px; }
  }
  @media screen and (max-width: 480px) {
    .gwmf-promo__inner { padding: var(--promo-pt) var(--promo-pr) var(--promo-pb) var(--promo-pl); }
  }
</style>

<section class="gwmf-promo" id="shopify-section-{{ section.id }}">
  <div class="gwmf-promo__waves-clip">
    <div class="gwmf-promo__wave-top"><svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"><path d="M0,0 C480,80 960,80 1440,0 Z" fill="#ffffff"/></svg></div>
    <div class="gwmf-promo__wave-bottom"><svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"><path d="M0,0 C480,80 960,80 1440,0 L1440,80 L0,80 Z" fill="#ffffff"/></svg></div>
  </div>
  {%- if section.settings.corner_image != blank -%}
    <div class="gwmf-promo__corner">{{ section.settings.corner_image | image_url: width: 600 | image_tag: alt: '', loading: 'lazy' }}</div>
  {%- endif -%}
  <div class="gwmf-promo__inner">
    <div class="gwmf-promo__content">
      {%- if section.settings.eyebrow != blank -%}<p class="gwmf-promo__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="gwmf-promo__heading">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.body != blank -%}<p class="gwmf-promo__body">{{ section.settings.body }}</p>{%- endif -%}
      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_link }}" class="gwmf-promo__btn">{{ section.settings.btn_label }}</a>
      {%- endif -%}
    </div>
    <div class="gwmf-promo__image-wrap">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1280 | image_tag: alt: shop.name, loading: 'lazy', widths: '600, 800, 1000, 1280' }}
      {%- else -%}
        <div class="gwmf-promo__img-placeholder"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg></div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var sec = document.querySelector('#shopify-section-{{ section.id }} .gwmf-promo');
    if (!sec) return;
    var io = new IntersectionObserver(function (entries) { if (entries[0].isIntersecting) { sec.classList.add('is-visible'); io.disconnect(); } }, { threshold: 0.1 });
    io.observe(sec);
  })();
</script>

{% schema %}
{
  "name": "Promo Banner",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#1e6b2e" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "#FFD600" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#ffffff" },
    { "type": "color", "id": "body_color", "label": "Body color", "default": "#e8e8e8" },
    { "type": "color", "id": "btn_color", "label": "Button background", "default": "#e8430a" },
    { "type": "color", "id": "btn_text_color", "label": "Button text color", "default": "#ffffff" },
    { "type": "color", "id": "btn_border_color", "label": "Button border color", "default": "#e8430a" },

    { "type": "header", "content": "Typography — Eyebrow" },
    { "type": "select", "id": "eye_font", "label": "Font family", "options": [{ "value": "Outfit, sans-serif", "label": "Outfit (Body)" }, { "value": "Dimbo, Outfit, sans-serif", "label": "Dimbo (Display)" }], "default": "Outfit, sans-serif" },
    { "type": "range", "id": "eye_size", "label": "Size (px)", "min": 10, "max": 100, "step": 1, "default": 15 },
    { "type": "select", "id": "eye_weight", "label": "Weight", "options": [{ "value": "400", "label": "400" }, { "value": "500", "label": "500" }, { "value": "600", "label": "600" }, { "value": "700", "label": "700" }, { "value": "800", "label": "800" }], "default": "700" },
    { "type": "select", "id": "eye_transform", "label": "Text transform", "options": [{ "value": "none", "label": "None" }, { "value": "uppercase", "label": "UPPERCASE" }, { "value": "lowercase", "label": "lowercase" }, { "value": "capitalize", "label": "Capitalize" }], "default": "none" },
    { "type": "range", "id": "eye_ls", "label": "Letter spacing (×0.1px)", "min": -20, "max": 200, "step": 5, "default": 0 },
    { "type": "range", "id": "eye_lh", "label": "Line height (÷10)", "min": 8, "max": 50, "step": 1, "default": 14 },
    { "type": "select", "id": "eye_style", "label": "Font style", "options": [{ "value": "normal", "label": "Normal" }, { "value": "italic", "label": "Italic" }], "default": "normal" },
    { "type": "select", "id": "eye_decoration", "label": "Text decoration", "options": [{ "value": "none", "label": "None" }, { "value": "underline", "label": "Underline" }, { "value": "line-through", "label": "Line-through" }], "default": "none" },

    { "type": "header", "content": "Typography — Heading" },
    { "type": "select", "id": "head_font", "label": "Font family", "options": [{ "value": "Outfit, sans-serif", "label": "Outfit (Body)" }, { "value": "Dimbo, Outfit, sans-serif", "label": "Dimbo (Display)" }], "default": "Outfit, sans-serif" },
    { "type": "range", "id": "head_size", "label": "Size — desktop (px)", "min": 24, "max": 224, "step": 2, "default": 58 },
    { "type": "select", "id": "head_weight", "label": "Weight", "options": [{ "value": "400", "label": "400" }, { "value": "500", "label": "500" }, { "value": "600", "label": "600" }, { "value": "700", "label": "700" }, { "value": "800", "label": "800" }, { "value": "900", "label": "900" }], "default": "800" },
    { "type": "select", "id": "head_transform", "label": "Text transform", "options": [{ "value": "none", "label": "None" }, { "value": "uppercase", "label": "UPPERCASE" }, { "value": "lowercase", "label": "lowercase" }, { "value": "capitalize", "label": "Capitalize" }], "default": "none" },
    { "type": "range", "id": "head_ls", "label": "Letter spacing (×0.1px)", "min": -20, "max": 200, "step": 5, "default": 0 },
    { "type": "range", "id": "head_lh", "label": "Line height (÷10)", "min": 6, "max": 50, "step": 1, "default": 11 },
    { "type": "select", "id": "head_style", "label": "Font style", "options": [{ "value": "normal", "label": "Normal" }, { "value": "italic", "label": "Italic" }], "default": "normal" },
    { "type": "select", "id": "head_decoration", "label": "Text decoration", "options": [{ "value": "none", "label": "None" }, { "value": "underline", "label": "Underline" }, { "value": "line-through", "label": "Line-through" }], "default": "none" },

