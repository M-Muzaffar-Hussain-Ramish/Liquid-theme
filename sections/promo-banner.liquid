    { "type": "range", "id": "btn_ls", "label": "Letter spacing (×0.1px)", "min": 0, "max": 200, "step": 5, "default": 0 },
    { "type": "range", "id": "btn_lh", "label": "Line height (÷10)", "min": 8, "max": 50, "step": 1, "default": 12 },
    { "type": "select", "id": "btn_style", "label": "Font style", "options": [{ "value": "normal", "label": "Normal" }, { "value": "italic", "label": "Italic" }], "default": "normal" },
    { "type": "select", "id": "btn_decoration", "label": "Text decoration", "options": [{ "value": "none", "label": "None" }, { "value": "underline", "label": "Underline" }, { "value": "line-through", "label": "Line-through" }], "default": "none" },

