{%- style -%}
  #shopify-section-{{ section.id }} {
    --promo-bg:      {{ section.settings.bg_color }};
    --promo-eyebrow: {{ section.settings.eyebrow_color }};
    --promo-heading: {{ section.settings.heading_color }};
    --promo-body:    {{ section.settings.body_color }};
    --promo-btn:     {{ section.settings.btn_color }};
    background-color: var(--promo-bg);
  }
{%- endstyle -%}

<style>
  .gwmf-promo {
    position: relative;
    width: 100%;
    overflow: visible;
  }

  /* Clip only the waves, not the decorative corner image */
  .gwmf-promo__waves-clip {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  /* ---- WAVES (same meniscus as press-quote) ---- */
  .gwmf-promo__wave-top,
  .gwmf-promo__wave-bottom {
    position: absolute;
    left: 0;
    width: 100%;
    line-height: 0;
    pointer-events: none;
  }

  .gwmf-promo__wave-top { top: -1px; }
  .gwmf-promo__wave-bottom { bottom: -1px; }

  .gwmf-promo__wave-top svg,
  .gwmf-promo__wave-bottom svg {
    display: block;
    width: 100%;
    height: 80px;
  }

  /* ---- DECORATIVE CORNER IMAGE (christmas tree etc) ---- */
  .gwmf-promo__corner {
    position: absolute;
    top: -20px;
    left: 0;
    z-index: 10;
    pointer-events: none;
  }

  .gwmf-promo__corner img {
    width: 100px;
    height: auto;
    display: block;
  }

  /* ---- LAYOUT ---- */
  .gwmf-promo__inner {
    position: relative;
    z-index: 3;
    max-width: 1400px;
    margin: 0 auto;
    padding: 100px 64px 100px 64px;
    display: grid;
    grid-template-columns: 50% 50%;
    align-items: center;
    gap: 0;
  }

  /* ---- LEFT — TEXT ---- */
  .gwmf-promo__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    padding-right: 32px;
  }

  .gwmf-promo__eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--promo-eyebrow);
    margin: 0;
    letter-spacing: 0.3px;
  }

  .gwmf-promo__heading {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(36px, 4vw, 58px);
    font-weight: 800;
    color: var(--promo-heading);
    line-height: 1.1;
    margin: 0;
    white-space: pre-line;
  }

  .gwmf-promo__body {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: var(--promo-body);
    line-height: 1.6;
    margin: 0;
    max-width: 480px;
  }

  .gwmf-promo__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px 44px;
    background: var(--promo-btn);
    color: #fff;
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    border-radius: 50px;
    transition: filter 0.2s, transform 0.15s;
    margin-top: 4px;
    min-width: 260px;
  }

  .gwmf-promo__btn:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
  }

  /* ---- RIGHT — IMAGE ---- */
  .gwmf-promo__image-wrap {
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    height: 100%;
  }

  .gwmf-promo__image-wrap img {
    width: 100%;
    max-width: 640px;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .gwmf-promo__img-placeholder {
    width: 100%;
    max-width: 640px;
    aspect-ratio: 16/10;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.3);
    border: 2px dashed rgba(255, 255, 255, 0.2);
  }

  /* ---- ANIMATIONS ---- */
  .gwmf-promo__eyebrow,
  .gwmf-promo__heading,
  .gwmf-promo__body,
  .gwmf-promo__btn,
  .gwmf-promo__image-wrap {
    opacity: 0;
    transition: opacity 0.65s ease, transform 0.65s ease;
  }

  .gwmf-promo__content > * {
    transform: translateX(-36px);
  }

  .gwmf-promo__image-wrap {
    transform: translateX(36px);
  }

  .gwmf-promo.is-visible .gwmf-promo__eyebrow {
    opacity: 1; transform: translateX(0); transition-delay: 0s;
  }
  .gwmf-promo.is-visible .gwmf-promo__heading {
    opacity: 1; transform: translateX(0); transition-delay: 0.1s;
  }
  .gwmf-promo.is-visible .gwmf-promo__body {
    opacity: 1; transform: translateX(0); transition-delay: 0.2s;
  }
  .gwmf-promo.is-visible .gwmf-promo__btn {
    opacity: 1; transform: translateX(0); transition-delay: 0.3s;
  }
  .gwmf-promo.is-visible .gwmf-promo__image-wrap {
    opacity: 1; transform: translateX(0); transition-delay: 0.15s;
  }

  /* ---- RESPONSIVE ---- */
  @media screen and (max-width: 989px) {
    .gwmf-promo__inner {
      grid-template-columns: 1fr;
      padding: 88px 32px 80px;
      gap: 32px;
      text-align: center;
    }
    .gwmf-promo__content {
      align-items: center;
      padding-right: 0;
      order: 1;
    }
    .gwmf-promo__image-wrap {
      justify-content: center;
      order: 2;
    }
    .gwmf-promo__body {
      max-width: 100%;
    }
    .gwmf-promo__corner img {
      width: 200px;
    }
    .gwmf-promo__wave-top svg,
    .gwmf-promo__wave-bottom svg {
      height: 56px;
    }
  }

  @media screen and (max-width: 749px) {
    .gwmf-promo__inner {
      padding: 72px 20px 64px;
      gap: 24px;
    }
    .gwmf-promo__heading {
      font-size: clamp(28px, 9vw, 42px);
    }
    .gwmf-promo__body {
      font-size: 15px;
    }
    .gwmf-promo__btn {
      width: 100%;
      max-width: 360px;
      min-width: unset;
    }
    .gwmf-promo__corner img {
      width: 140px;
    }
    .gwmf-promo__wave-top svg,
    .gwmf-promo__wave-bottom svg {
      height: 40px;
    }
  }

  @media screen and (max-width: 480px) {
    .gwmf-promo__inner {
      padding: 60px 16px 52px;
    }
    .gwmf-promo__corner img {
      width: 110px;
    }
  }
</style>

<section class="gwmf-promo" id="shopify-section-{{ section.id }}">
  <!-- Waves inside clip wrapper so they don't affect corner image overflow -->
  <div class="gwmf-promo__waves-clip">
    <div class="gwmf-promo__wave-top">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 C480,80 960,80 1440,0 Z" fill="#ffffff"/>
      </svg>
    </div>
    <div class="gwmf-promo__wave-bottom">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 C480,80 960,80 1440,0 L1440,80 L0,80 Z" fill="#ffffff"/>
      </svg>
    </div>
  </div>

  <!-- Corner decorative image — outside clip so it can overflow above the wave -->
  {%- if section.settings.corner_image != blank -%}
    <div class="gwmf-promo__corner">
      {%- assign corner_alt = section.settings.corner_image.alt | default: '' | escape -%}
      {{ section.settings.corner_image | image_url: width: 600 | image_tag: alt: corner_alt, loading: 'lazy' }}
    </div>
  {%- endif -%}

  <div class="gwmf-promo__inner">
    <!-- LEFT: Text -->
    <div class="gwmf-promo__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="gwmf-promo__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="gwmf-promo__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <p class="gwmf-promo__body">{{ section.settings.body }}</p>
      {%- endif -%}

      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_link }}" class="gwmf-promo__btn">
          {{ section.settings.btn_label }}
        </a>
      {%- endif -%}
    </div>

    <!-- RIGHT: Image -->
    <div class="gwmf-promo__image-wrap">
      {%- if section.settings.image != blank -%}
        {%- assign img_alt = section.settings.image.alt | default: shop.name | escape -%}
        {{
          section.settings.image
          | image_url: width: 1280
          | image_tag: alt: img_alt, loading: 'lazy', widths: '600, 800, 1000, 1280'
        }}
      {%- else -%}
        <div class="gwmf-promo__img-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/>
          </svg>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var sec = document.querySelector('#shopify-section-{{ section.id }} .gwmf-promo');
    if (!sec) return;
    var io = new IntersectionObserver(
      function (entries) {
        if (entries[0].isIntersecting) {
          sec.classList.add('is-visible');
          io.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    io.observe(sec);
  })();
</script>

{% schema %}
{
  "name": "Promo Banner",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1e6b2e"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow text color",
      "default": "#FFD600"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text color",
      "default": "#e8e8e8"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button color",
      "default": "#e8430a"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "corner_image",
      "label": "Corner decorative image (e.g. Christmas tree)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Limited Holiday Designs Available"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Buy any 3 products\nGet 1 free"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Get exclusive savings when you bundle multiple face wraps. Great for families, parties, or coworkers!"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Create a Custom Bundle"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link",
      "default": "/collections/all"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right column image (gift wrap rolls etc)"
    }
  ],
  "presets": [
    {
      "name": "Promo Banner"
    }
  ]
}
{% endschema %}
