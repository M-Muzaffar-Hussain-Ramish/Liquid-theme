{%- style -%}
  #shopify-section-{{ section.id }} {
    --blog-bg:       {{ section.settings.bg_color }};
    --blog-eyebrow:  {{ section.settings.eyebrow_color }};
    --blog-heading:  {{ section.settings.heading_color }};
    --blog-btn-bg:   {{ section.settings.btn_bg_color }};
    --blog-btn-text: {{ section.settings.btn_text_color }};
    background-color: var(--blog-bg);
  }
{%- endstyle -%}

<style>
  .gwmf-blog {
    width: 100%;
  }

  .gwmf-blog__inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 72px 74px 25px;
    text-align: center;
  }

  .gwmf-blog__eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--blog-eyebrow);
    margin: 0 0 14px;
  }

  .gwmf-blog__heading {
    font-family: 'Dimbo', 'Outfit', sans-serif;
    font-size: clamp(36px, 4.5vw, 60px);
    font-weight: 800;
    color: var(--blog-heading);
    line-height: 1.05;
    margin: 0 0 48px;
  }

  .gwmf-blog__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    text-align: left;
  }

  .gwmf-blog__card {
    background: var(--card-bg, #f5f0eb);
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .gwmf-blog__card-img-wrap {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    flex-shrink: 0;
  }

  .gwmf-blog__card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .gwmf-blog__card:hover .gwmf-blog__card-img-wrap img {
    transform: scale(1.04);
  }

  .gwmf-blog__card-img-placeholder {
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(0, 0, 0, 0.2);
  }

  .gwmf-blog__card-content {
    padding: 28px 32px 36px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
    flex: 1;
  }

  .gwmf-blog__card-eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;
    margin: 0;
  }

  .gwmf-blog__card-heading {
    font-family: 'Dimbo', 'Outfit', sans-serif;
    font-size: clamp(24px, 2.5vw, 36px);
    font-weight: 800;
    line-height: 1.1;
    margin: 0;
  }

  .gwmf-blog__card-body {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .gwmf-blog__card-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    background: var(--blog-btn-bg);
    color: var(--blog-btn-text);
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    border-radius: 8px;
    transition: filter 0.2s, transform 0.15s;
    margin-top: 4px;
  }

  .gwmf-blog__card-btn:hover {
    filter: brightness(0.85);
    transform: translateY(-2px);
  }

  /* ---- ANIMATIONS ---- */
  .gwmf-blog__eyebrow,
  .gwmf-blog__heading,
  .gwmf-blog__card {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .gwmf-blog.is-visible .gwmf-blog__eyebrow {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0s;
  }
  .gwmf-blog.is-visible .gwmf-blog__heading {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.1s;
  }
  .gwmf-blog.is-visible .gwmf-blog__card:nth-child(1) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.22s;
  }
  .gwmf-blog.is-visible .gwmf-blog__card:nth-child(2) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.36s;
  }

  /* ---- RESPONSIVE ---- */
  @media screen and (max-width: 989px) {
    .gwmf-blog__inner {
      padding: 52px 32px 60px;
    }
    .gwmf-blog__grid {
      gap: 20px;
    }
    .gwmf-blog__card-content {
      padding: 22px 24px 28px;
    }
  }

  @media screen and (max-width: 749px) {
    .gwmf-blog__inner {
      padding: 40px 16px 48px;
    }
    .gwmf-blog__grid {
      grid-template-columns: 1fr;
      max-width: 520px;
      margin-left: auto;
      margin-right: auto;
      gap: 24px;
    }
    .gwmf-blog__heading {
      margin-bottom: 36px;
    }
  }

  @media screen and (max-width: 480px) {
    .gwmf-blog__inner {
      padding: 32px 14px 40px;
    }
    .gwmf-blog__card-content {
      padding: 18px 18px 24px;
      gap: 12px;
    }
    .gwmf-blog__card-btn {
      font-size: 12px;
      padding: 12px 22px;
    }
  }
</style>

<section class="gwmf-blog" id="shopify-section-{{ section.id }}">
  <div class="gwmf-blog__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="gwmf-blog__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="gwmf-blog__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="gwmf-blog__grid">
        {%- for block in section.blocks -%}
          {%- assign art = block.settings.article -%}
          <div
            class="gwmf-blog__card"
            style="--card-bg: {{ block.settings.card_bg_color }};"
            {{ block.shopify_attributes }}
          >
            <div class="gwmf-blog__card-img-wrap">
              {%- if art != blank and art.image != blank -%}
                {%- assign img_alt = art.image.alt | default: art.title | escape -%}
                {{
                  art.image
                  | image_url: width: 800
                  | image_tag: alt: img_alt, loading: 'lazy', widths: '400, 600, 800'
                }}
              {%- else -%}
                <div class="gwmf-blog__card-img-placeholder">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/>
                  </svg>
                </div>
              {%- endif -%}
            </div>

            <div class="gwmf-blog__card-content">
              {%- if art != blank and art.tags.size > 0 -%}
                <p class="gwmf-blog__card-eyebrow" style="color: {{ block.settings.eyebrow_color }};">
                  {{ art.tags | first }}
                </p>
              {%- endif -%}

              {%- if art != blank -%}
                <h3 class="gwmf-blog__card-heading" style="color: {{ block.settings.heading_color }};">
                  {{ art.title }}
                </h3>
                {%- if art.excerpt != blank -%}
                  <p class="gwmf-blog__card-body" style="color: {{ block.settings.body_color }};">
                    {{ art.excerpt | strip_html | truncate: 180 }}
                  </p>
                {%- endif -%}
              {%- endif -%}

              {%- assign btn_href = block.settings.btn_link | default: art.url -%}
              {%- if block.settings.btn_label != blank -%}
                <a href="{{ btn_href }}" class="gwmf-blog__card-btn">
                  {{ block.settings.btn_label }}
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    var sec = document.querySelector('#shopify-section-{{ section.id }} .gwmf-blog');
    if (!sec) return;
    var io = new IntersectionObserver(
      function (entries) {
        if (entries[0].isIntersecting) {
          sec.classList.add('is-visible');
          io.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    io.observe(sec);
  })();
</script>

{% schema %}
{
  "name": "Blog Cards",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#1a5fbe"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a5fbe"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button background color",
      "default": "#1a3a6e"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "From Christmas to birthdays – even your pet's face is fair game"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Other Products"
    }
  ],
  "blocks": [
    {
      "type": "article_card",
      "name": "Article Card",
      "settings": [
        {
          "type": "article",
          "id": "article",
          "label": "Article"
        },
        {
          "type": "color",
          "id": "card_bg_color",
          "label": "Card background color",
          "default": "#f5f0eb"
        },
        {
          "type": "color",
          "id": "eyebrow_color",
          "label": "Eyebrow text color",
          "default": "#1a5fbe"
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Heading color",
          "default": "#1a3a6e"
        },
        {
          "type": "color",
          "id": "body_color",
          "label": "Body text color",
          "default": "#555555"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button link (overrides article URL)"
        }
      ]
    }
  ],
  "max_blocks": 2,
  "presets": [
    {
      "name": "Blog Cards",
      "blocks": [
        {
          "type": "article_card",
          "settings": {
            "card_bg_color": "#f5f0eb",
            "eyebrow_color": "#1a5fbe",
            "heading_color": "#1a3a6e",
            "body_color": "#555555",
            "btn_label": "Order Your Holiday Pair Now"
          }
        },
        {
          "type": "article_card",
          "settings": {
            "card_bg_color": "#e8f0f8",
            "eyebrow_color": "#1a5fbe",
            "heading_color": "#1a3a6e",
            "body_color": "#555555",
            "btn_label": "Shop Now"
          }
        }
      ]
    }
  ]
}
{% endschema %}
