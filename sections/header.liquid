<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Amatic+SC:wght@700&display=swap"
  rel="stylesheet"
>

<style>
  /* ===== GWMF HEADER ===== */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  .gwmf-header-wrapper {
    background: #fff;
    border-bottom: 2px solid #1a6fcc;
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
  }

  .gwmf-header {
    display: flex;
    align-items: center;
    max-width: 1300px;
    margin: 0 auto;
    padding: 10px 24px;
    gap: 16px;
    min-height: 64px;
  }

  /* --- LOGO --- */
  .gwmf-logo {
    flex-shrink: 0;
  }
  .gwmf-logo a {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .gwmf-logo img {
    height: 27px;
    width: 223px;
    display: block;
    object-fit: contain;
  }

  /* --- DESKTOP NAV --- */
  .gwmf-nav {
    flex: 1;
    display: flex;
    justify-content: center;
    min-width: 0;
  }
  .gwmf-nav-list {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 2px;
    flex-wrap: nowrap;
  }
  .gwmf-nav-item {
    position: relative;
  }
  .gwmf-nav-link {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 10px 12px;
    font-family: 'Dimbo', sans-serif;
    font-size: 22px;
    font-weight: 400;
    color: #222;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
    transition: color 0.2s;
    border-radius: 4px;
  }
  .gwmf-nav-link:hover {
    color: #1a6fcc;
  }
  .gwmf-nav-link .chevron {
    width: 9px;
    height: 9px;
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .gwmf-nav-item:hover .gwmf-nav-link .chevron {
    transform: rotate(180deg);
  }

  /* --- DROPDOWN BASE --- */
  .gwmf-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    background: #fff;
    min-width: 200px;
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.12);
    z-index: 200;
    border-radius: 14px;
    /* Hidden state — JS toggles .is-open */
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s ease, visibility 0s linear 0.22s;
  }
  .gwmf-dropdown.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0s linear 0s;
  }
  .gwmf-dropdown-list {
    list-style: none;
    margin: 0;
    padding: 8px 0;
  }
  .gwmf-dropdown-link {
    display: block;
    padding: 14px 24px;
    font-family: 'Dimbo', sans-serif;
    font-size: 22px;
    font-weight: 400;
    color: #222;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid #eee;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .gwmf-dropdown-link:last-child {
    border-bottom: none;
  }
  .gwmf-dropdown-link:hover {
    color: #1a6fcc;
  }

  /* Mega menu */
  .gwmf-dropdown--mega {
    min-width: 700px;
    left: 50%;
  }
  .gwmf-nav-item:last-child .gwmf-dropdown--mega,
  .gwmf-nav-item:nth-last-child(2) .gwmf-dropdown--mega {
    left: auto;
    right: 0;
    transform: translateY(8px);
  }
  .gwmf-nav-item:last-child .gwmf-dropdown--mega.is-open,
  .gwmf-nav-item:nth-last-child(2) .gwmf-dropdown--mega.is-open {
    transform: translateY(0);
  }
  .gwmf-dropdown--mega .gwmf-dropdown-list {
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }
  .gwmf-dropdown--mega .gwmf-dropdown-link {
    white-space: normal;
    padding: 15px 24px;
    border-bottom: 1px solid #e8e8e8;
  }

  /* --- RIGHT ICONS --- */
  .gwmf-icons {
    display: flex;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
  }
  .gwmf-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    background: none;
    border: none;
    cursor: pointer;
    color: #333;
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
    position: relative;
  }
  .gwmf-icon-btn:hover {
    color: #1a6fcc;
    background: #f4f8ff;
  }
  .gwmf-icon-btn svg {
    width: 22px;
    height: 22px;
  }
  .gwmf-cart-count {
    position: absolute;
    top: 4px;
    right: 4px;
    background: #1a6fcc;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    font-family: 'Outfit', sans-serif;
    min-width: 17px;
    height: 17px;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    line-height: 1;
  }

  /* --- MOBILE TOGGLE --- */
  .gwmf-mobile-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: #333;
    flex-shrink: 0;
    width: 40px;
  }
  .gwmf-mobile-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: currentColor;
    transition: all 0.25s;
    border-radius: 2px;
  }
  .gwmf-mobile-toggle.is-open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .gwmf-mobile-toggle.is-open span:nth-child(2) {
    opacity: 0;
  }
  .gwmf-mobile-toggle.is-open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* --- OVERLAY --- */
  .gwmf-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 300;
  }
  .gwmf-overlay.is-open {
    display: block;
  }

  /* --- MOBILE MENU --- */
  .gwmf-mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 300px;
    max-width: 88vw;
    height: 100%;
    background: #fff;
    z-index: 400;
    overflow-y: auto;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .gwmf-mobile-menu.is-open {
    transform: translateX(0);
  }
  .gwmf-mobile-menu-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid #eee;
    flex-shrink: 0;
  }
  .gwmf-mobile-close {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 26px;
    color: #333;
    line-height: 1;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 6px;
  }
  .gwmf-mobile-close:hover {
    background: #f4f8ff;
  }
  .gwmf-mobile-nav {
    flex: 1;
    overflow-y: auto;
  }
  .gwmf-mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .gwmf-mobile-nav-item {
    border-bottom: 1px solid #f0f0f0;
  }
  .gwmf-mobile-nav-row {
    display: flex;
    align-items: stretch;
  }
  .gwmf-mobile-nav-link {
    flex: 1;
    display: block;
    padding: 15px 20px;
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #222;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.4px;
  }
  .gwmf-mobile-nav-link:hover {
    color: #1a6fcc;
  }
  .gwmf-mobile-sub-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    background: none;
    border: none;
    border-left: 1px solid #f0f0f0;
    cursor: pointer;
    color: #666;
    transition: background 0.15s;
    flex-shrink: 0;
  }
  .gwmf-mobile-sub-toggle:hover {
    background: #f4f8ff;
  }
  .gwmf-mobile-sub-toggle svg {
    width: 12px;
    height: 12px;
    transition: transform 0.2s;
  }
  .gwmf-mobile-sub-toggle.is-open svg {
    transform: rotate(180deg);
  }
  .gwmf-mobile-submenu {
    display: none;
    background: #f9f9f9;
    border-top: 1px solid #eee;
  }
  .gwmf-mobile-submenu.is-open {
    display: block;
  }
  .gwmf-mobile-submenu-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .gwmf-mobile-submenu-link {
    display: block;
    padding: 12px 20px 12px 32px;
    font-family: 'Outfit', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: #555;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    border-bottom: 1px solid #efefef;
    transition: color 0.15s, background 0.15s;
  }
  .gwmf-mobile-submenu-link:last-child {
    border-bottom: none;
  }
  .gwmf-mobile-submenu-link:hover {
    color: #1a6fcc;
    background: #f0f6ff;
  }
  .gwmf-mobile-footer {
    padding: 20px;
    border-top: 2px solid #eee;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex-shrink: 0;
  }
  .gwmf-mobile-footer-link {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #333;
    text-decoration: none;
    padding: 10px 4px;
    border-radius: 6px;
    transition: color 0.15s;
  }
  .gwmf-mobile-footer-link svg {
    width: 20px;
    height: 20px;
    color: #666;
    flex-shrink: 0;
  }
  .gwmf-mobile-footer-link:hover {
    color: #1a6fcc;
  }

  /* --- SEARCH MODAL --- */
  .gwmf-search-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: #fff;
    z-index: 500;
    padding: 20px 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }
  .gwmf-search-modal.is-open {
    display: block;
  }
  .gwmf-search-inner {
    max-width: 640px;
    margin: 0 auto;
    position: relative;
  }
  .gwmf-search-form {
    display: flex;
    gap: 8px;
  }
  .gwmf-search-input {
    flex: 1;
    min-width: 0;
    padding: 12px 16px;
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    border: 2px solid #1a6fcc;
    border-radius: 6px;
    outline: none;
    color: #222;
  }
  .gwmf-search-input::placeholder {
    color: #aaa;
  }
  .gwmf-search-submit {
    padding: 12px 20px;
    background: #1a6fcc;
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 600;
    white-space: nowrap;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .gwmf-search-submit:hover {
    background: #1558a8;
  }
  .gwmf-search-close {
    position: absolute;
    top: -8px;
    right: -8px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 28px;
    color: #666;
    line-height: 1;
    padding: 4px;
  }
  .gwmf-search-close:hover {
    color: #222;
  }

  /* ===== RESPONSIVE ===== */

  /* Tablet/mobile: hide desktop nav, show hamburger, center logo */
  @media screen and (max-width: 989px) {
    .gwmf-nav {
      display: none;
    }
    .gwmf-mobile-toggle {
      display: flex;
    }
    .gwmf-header {
      position: relative;
      justify-content: space-between;
      padding: 8px 14px;
      min-height: 54px;
    }
    .gwmf-logo {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }
    .gwmf-logo img {
      height: 28px;
      max-width: 140px;
      object-fit: contain;
    }
    /* Hide account icon — it lives in the mobile menu footer */
    .gwmf-account-btn {
      display: none;
    }
    .gwmf-icons {
      gap: 0;
    }
    .gwmf-icon-btn {
      width: 38px;
      height: 38px;
    }
    .gwmf-icon-btn svg {
      width: 20px;
      height: 20px;
    }
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    .gwmf-header {
      padding: 6px 12px;
      min-height: 50px;
    }
    .gwmf-logo img {
      height: 26px;
      max-width: 120px;
    }
    .gwmf-search-modal {
      padding: 16px 14px;
    }
    .gwmf-search-submit {
      padding: 12px 14px;
      font-size: 13px;
    }
  }

  /* Very small screens */
  @media screen and (max-width: 400px) {
    .gwmf-header {
      padding: 6px 10px;
    }
    .gwmf-logo img {
      height: 22px;
      max-width: 100px;
    }
    .gwmf-icon-btn {
      width: 34px;
      height: 34px;
    }
    .gwmf-icon-btn svg {
      width: 18px;
      height: 18px;
    }
  }
</style>

<div class="gwmf-overlay" id="gwmf-overlay"></div>

{%- liquid
  assign menu_handle = section.settings.menu | default: 'main-menu'
  if linklists[menu_handle].links.size == 0
    assign menu_handle = 'main-menu-1'
  endif
-%}

<div class="gwmf-header-wrapper">
  <div class="gwmf-header">

    {%- comment -%} Mobile hamburger {%- endcomment -%}
    <button
      class="gwmf-mobile-toggle"
      id="gwmf-mobile-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="gwmf-mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    {%- comment -%} Logo {%- endcomment -%}
    <div class="gwmf-logo">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        <img
          src="{{ 'logo.webp' | asset_url }}"
          alt="{{ shop.name | escape }}"
          height="44"
          width="auto"
          loading="eager"
        >
      </a>
    </div>

    {%- comment -%} Desktop Navigation {%- endcomment -%}
    <nav class="gwmf-nav" role="navigation" aria-label="Main navigation">
      <ul class="gwmf-nav-list" role="list">
        {%- for link in linklists[menu_handle].links -%}
          <li class="gwmf-nav-item" role="listitem">
            {%- if link.links != blank -%}
              <a
                href="{{ link.url }}"
                class="gwmf-nav-link"
                aria-haspopup="true"
                aria-expanded="false"
                {% if link.active %}aria-current="page"{% endif %}
              >
                {{- link.title -}}
                <svg class="chevron" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                  <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <div
                class="gwmf-dropdown{% if link.links.size >= 6 %} gwmf-dropdown--mega{% endif %}"
                role="region"
                aria-label="{{ link.title }} submenu"
              >
                <ul class="gwmf-dropdown-list" role="list">
                  {%- for child_link in link.links -%}
                    <li role="listitem">
                      <a
                        href="{{ child_link.url }}"
                        class="gwmf-dropdown-link"
                        {% if child_link.active %}aria-current="page"{% endif %}
                      >
                        {{- child_link.title -}}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- else -%}
              <a
                href="{{ link.url }}"
                class="gwmf-nav-link"
                {% if link.active %}aria-current="page"{% endif %}
              >
                {{- link.title -}}
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment -%} Right Icons {%- endcomment -%}
    <div class="gwmf-icons">
      <button
        class="gwmf-icon-btn"
        id="gwmf-search-toggle"
        aria-label="Search"
        aria-expanded="false"
        aria-controls="gwmf-search-modal"
      >
        <svg viewBox="0 0 23 23" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M13.48 0.03C8.498 0.03 4.46 4.068 4.46 9.049C4.46 11.237 5.24 13.243 6.536 14.805L0.5 20.814L1.715 22.029L7.739 16.006C9.286 17.29 11.292 18.069 13.48 18.069C18.462 18.069 22.5 14.031 22.5 9.049C22.5 4.068 18.462 0.03 13.48 0.03ZM13.48 16.354C9.446 16.354 6.176 13.084 6.176 9.051C6.176 5.017 9.446 1.748 13.48 1.748C17.512 1.748 20.782 5.017 20.782 9.051C20.778 13.082 17.511 16.35 13.48 16.354Z" fill="currentColor"/>
        </svg>
      </button>

      <a
        href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
        class="gwmf-icon-btn gwmf-account-btn"
        aria-label="{%- if customer -%}My account{%- else -%}Sign in{%- endif -%}"
        rel="nofollow"
      >
        <svg viewBox="0 0 25 23" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M20.277 14.253C19.132 13.104 17.734 12.208 16.173 11.655C17.774 10.47 18.86 8.555 18.86 6.387C18.86 2.875 16.012 0.027 12.5 0.027C8.988 0.027 6.14 2.875 6.14 6.387C6.14 8.555 7.225 10.47 8.903 11.632C4.56 13.173 1.505 17.244 1.5 22.03H3.219C3.219 16.904 7.374 12.749 12.5 12.749C17.626 12.749 21.781 16.904 21.781 22.03H23.5C23.5 18.975 22.268 16.234 20.277 14.253ZM12.5 11.03C9.936 11.03 7.858 8.952 7.858 6.389C7.858 3.826 9.936 1.748 12.5 1.748C15.063 1.748 17.14 3.826 17.14 6.389C17.137 8.951 15.062 11.027 12.5 11.03Z" fill="currentColor"/>
        </svg>
      </a>

      <a href="{{ routes.cart_url }}" class="gwmf-icon-btn" aria-label="Cart ({{ cart.item_count }} items)">
        <svg viewBox="0 0 25 23" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M24.47 2.204L23.351 11.45C23.24 12.326 22.55 13.004 21.678 13.091L7.294 14.365H7.26L6.7 14.415C6.154 14.418 5.99 14.165 5.99 14.165C5.084 13.778 4.433 12.949 4.302 11.942L3.013 2.156H1.424C0.908 2.156 0.49 1.738 0.49 1.222C0.49 0.706 0.908 0.288 1.424 0.288H3.013C3.949 0.297 4.84 1.908 4.84 1.908L4.966 2.849L23.471 1.209C23.943 1.205 24.47 1.796 24.47 2.204ZM5.206 4.702L6.13 11.697C6.193 12.156 6.583 12.506 7.054 12.506L21.518 11.227L22.497 3.17L5.206 4.702ZM9.4 15.232C11.205 15.232 12.669 16.695 12.669 18.501C12.669 20.306 11.205 21.77 9.4 21.77C7.594 21.77 6.13 20.306 6.13 18.501C6.143 16.715 7.576 15.269 9.358 15.234L9.4 15.232ZM9.4 19.901C10.15 19.901 10.777 19.275 10.777 18.503C10.777 17.73 10.15 17.104 9.378 17.104C8.605 17.104 7.979 17.73 7.979 18.502C7.992 19.263 8.599 19.878 9.378 19.901H9.4ZM18.121 15.232C19.968 15.232 21.432 16.695 21.432 18.501C21.432 20.306 19.968 21.77 18.163 21.77C16.357 21.77 14.893 20.306 14.893 18.501C14.908 16.716 16.34 15.271 18.121 15.234V15.232ZM18.121 19.901C18.908 19.901 19.535 19.275 19.535 18.503C19.535 17.73 18.908 17.104 18.136 17.104C17.363 17.104 16.737 17.73 16.737 18.502C16.752 19.264 17.361 19.879 18.121 19.901Z" fill="currentColor"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="gwmf-cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>

  </div>
</div>

{%- comment -%} Search Modal {%- endcomment -%}
<div
  class="gwmf-search-modal"
  id="gwmf-search-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Search"
  aria-hidden="true"
>
  <div class="gwmf-search-inner">
    <button class="gwmf-search-close" id="gwmf-search-close" aria-label="Close search">&times;</button>
    <form class="gwmf-search-form" action="{{ routes.search_url }}" method="get" role="search">
      <input type="hidden" name="type" value="product">
      <input
        class="gwmf-search-input"
        type="search"
        name="q"
        id="gwmf-search-input"
        placeholder="Search products..."
        autocomplete="off"
        aria-label="Search products"
      >
      <button type="submit" class="gwmf-search-submit">Search</button>
    </form>
  </div>
</div>

{%- comment -%} Mobile Menu {%- endcomment -%}
<div
  class="gwmf-mobile-menu"
  id="gwmf-mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  aria-hidden="true"
>
  <div class="gwmf-mobile-menu-top">
    <div class="gwmf-logo">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        <img src="{{ 'logo.webp' | asset_url }}" alt="{{ shop.name | escape }}" height="36" loading="lazy">
      </a>
    </div>
    <button class="gwmf-mobile-close" id="gwmf-mobile-close" aria-label="Close menu">&times;</button>
  </div>

  <nav class="gwmf-mobile-nav" aria-label="Mobile navigation">
    <ul class="gwmf-mobile-nav-list" role="list">
      {%- for link in linklists[menu_handle].links -%}
        <li class="gwmf-mobile-nav-item">
          {%- if link.links != blank -%}
            <div class="gwmf-mobile-nav-row">
              <a href="{{ link.url }}" class="gwmf-mobile-nav-link">{{ link.title }}</a>
              <button
                class="gwmf-mobile-sub-toggle"
                aria-label="Expand {{ link.title }}"
                aria-expanded="false"
                data-sub-id="gwmf-sub-{{ forloop.index }}"
              >
                <svg viewBox="0 0 12 8" fill="none" aria-hidden="true">
                  <path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </button>
            </div>
            <div class="gwmf-mobile-submenu" id="gwmf-sub-{{ forloop.index }}" aria-hidden="true">
              <ul class="gwmf-mobile-submenu-list" role="list">
                {%- for child_link in link.links -%}
                  <li>
                    <a href="{{ child_link.url }}" class="gwmf-mobile-submenu-link">{{ child_link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- else -%}
            <div class="gwmf-mobile-nav-row">
              <a href="{{ link.url }}" class="gwmf-mobile-nav-link">{{ link.title }}</a>
            </div>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </nav>

  <div class="gwmf-mobile-footer">
    <a
      href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
      class="gwmf-mobile-footer-link"
      rel="nofollow"
    >
      <svg viewBox="0 0 25 23" fill="none" aria-hidden="true">
        <path d="M20.277 14.253C19.132 13.104 17.734 12.208 16.173 11.655C17.774 10.47 18.86 8.555 18.86 6.387C18.86 2.875 16.012 0.027 12.5 0.027C8.988 0.027 6.14 2.875 6.14 6.387C6.14 8.555 7.225 10.47 8.903 11.632C4.56 13.173 1.505 17.244 1.5 22.03H3.219C3.219 16.904 7.374 12.749 12.5 12.749C17.626 12.749 21.781 16.904 21.781 22.03H23.5C23.5 18.975 22.268 16.234 20.277 14.253ZM12.5 11.03C9.936 11.03 7.858 8.952 7.858 6.389C7.858 3.826 9.936 1.748 12.5 1.748C15.063 1.748 17.14 3.826 17.14 6.389C17.137 8.951 15.062 11.027 12.5 11.03Z" fill="currentColor"/>
      </svg>
      {%- if customer -%}My Account{%- else -%}Sign In{%- endif -%}
    </a>
    <a href="{{ routes.cart_url }}" class="gwmf-mobile-footer-link">
      <svg viewBox="0 0 25 23" fill="none" aria-hidden="true">
        <path d="M24.47 2.204L23.351 11.45C23.24 12.326 22.55 13.004 21.678 13.091L7.294 14.365H7.26L6.7 14.415C6.154 14.418 5.99 14.165 5.99 14.165C5.084 13.778 4.433 12.949 4.302 11.942L3.013 2.156H1.424C0.908 2.156 0.49 1.738 0.49 1.222C0.49 0.706 0.908 0.288 1.424 0.288H3.013C3.949 0.297 4.84 1.908 4.84 1.908L4.966 2.849L23.471 1.209C23.943 1.205 24.47 1.796 24.47 2.204ZM5.206 4.702L6.13 11.697C6.193 12.156 6.583 12.506 7.054 12.506L21.518 11.227L22.497 3.17L5.206 4.702ZM9.4 15.232C11.205 15.232 12.669 16.695 12.669 18.501C12.669 20.306 11.205 21.77 9.4 21.77C7.594 21.77 6.13 20.306 6.13 18.501C6.143 16.715 7.576 15.269 9.358 15.234L9.4 15.232ZM9.4 19.901C10.15 19.901 10.777 19.275 10.777 18.503C10.777 17.73 10.15 17.104 9.378 17.104C8.605 17.104 7.979 17.73 7.979 18.502C7.992 19.263 8.599 19.878 9.378 19.901H9.4ZM18.121 15.232C19.968 15.232 21.432 16.695 21.432 18.501C21.432 20.306 19.968 21.77 18.163 21.77C16.357 21.77 14.893 20.306 14.893 18.501C14.908 16.716 16.34 15.271 18.121 15.234V15.232ZM18.121 19.901C18.908 19.901 19.535 19.275 19.535 18.503C19.535 17.73 18.908 17.104 18.136 17.104C17.363 17.104 16.737 17.73 16.737 18.502C16.752 19.264 17.361 19.879 18.121 19.901Z" fill="currentColor"/>
      </svg>
      Cart
      {%- if cart.item_count > 0 -%}
        <span>({{ cart.item_count }})</span>
      {%- endif -%}
    </a>
  </div>
</div>

<script>
  (function () {
    /* ---- Desktop dropdown with 350ms close delay ---- */
    document.querySelectorAll('.gwmf-nav-item').forEach(function (item) {
      var dropdown = item.querySelector('.gwmf-dropdown');
      if (!dropdown) return;

      var closeTimer = null;

      function openDropdown() {
        clearTimeout(closeTimer);
        dropdown.classList.add('is-open');
      }

      function scheduleClose() {
        clearTimeout(closeTimer);
        closeTimer = setTimeout(function () {
          dropdown.classList.remove('is-open');
        }, 350);
      }

      /* Hovering the nav link opens it */
      item.addEventListener('mouseenter', openDropdown);
      item.addEventListener('mouseleave', scheduleClose);

      /* Moving into the dropdown itself cancels the close timer */
      dropdown.addEventListener('mouseenter', openDropdown);
      dropdown.addEventListener('mouseleave', scheduleClose);
    });

    /* ---- Mobile menu & search ---- */
    var overlay = document.getElementById('gwmf-overlay');
    var mobileToggle = document.getElementById('gwmf-mobile-toggle');
    var mobileMenu = document.getElementById('gwmf-mobile-menu');
    var mobileClose = document.getElementById('gwmf-mobile-close');
    var searchToggle = document.getElementById('gwmf-search-toggle');
    var searchModal = document.getElementById('gwmf-search-modal');
    var searchClose = document.getElementById('gwmf-search-close');
    var searchInput = document.getElementById('gwmf-search-input');

    function openMobile() {
      mobileMenu.classList.add('is-open');
      mobileMenu.setAttribute('aria-hidden', 'false');
      mobileToggle.classList.add('is-open');
      mobileToggle.setAttribute('aria-expanded', 'true');
      overlay.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    function closeMobile() {
      mobileMenu.classList.remove('is-open');
      mobileMenu.setAttribute('aria-hidden', 'true');
      mobileToggle.classList.remove('is-open');
      mobileToggle.setAttribute('aria-expanded', 'false');
      overlay.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    function openSearch() {
      searchModal.classList.add('is-open');
      searchModal.setAttribute('aria-hidden', 'false');
      searchToggle.setAttribute('aria-expanded', 'true');
      setTimeout(function () { searchInput && searchInput.focus(); }, 50);
    }

    function closeSearch() {
      searchModal.classList.remove('is-open');
      searchModal.setAttribute('aria-hidden', 'true');
      searchToggle.setAttribute('aria-expanded', 'false');
    }

    function closeAll() { closeMobile(); closeSearch(); }

    mobileToggle && mobileToggle.addEventListener('click', function () {
      mobileMenu.classList.contains('is-open') ? closeMobile() : openMobile();
    });
    mobileClose && mobileClose.addEventListener('click', closeMobile);
    searchToggle && searchToggle.addEventListener('click', function () {
      searchModal.classList.contains('is-open') ? closeSearch() : openSearch();
    });
    searchClose && searchClose.addEventListener('click', closeSearch);
    overlay && overlay.addEventListener('click', closeAll);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeAll();
    });

    document.querySelectorAll('.gwmf-mobile-sub-toggle').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var subId = btn.getAttribute('data-sub-id');
        var sub = document.getElementById(subId);
        if (!sub) return;
        var open = sub.classList.toggle('is-open');
        btn.classList.toggle('is-open', open);
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        sub.setAttribute('aria-hidden', open ? 'false' : 'true');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Navigation menu"
    }
  ]
}
{% endschema %}
