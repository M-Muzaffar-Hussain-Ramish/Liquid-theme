    { "type": "select", "id": "btn_transform", "label": "Text transform", "options": [{ "value": "none", "label": "None" }, { "value": "uppercase", "label": "UPPERCASE" }, { "value": "lowercase", "label": "lowercase" }, { "value": "capitalize", "label": "Capitalize" }], "default": "uppercase" },
    { "type": "range", "id": "btn_ls", "label": "Letter spacing (×0.1px)", "min": 0, "max": 200, "step": 5, "default": 10 },
    { "type": "range", "id": "btn_lh", "label": "Line height (÷10)", "min": 8, "max": 50, "step": 1, "default": 12 },
    { "type": "select", "id": "btn_style", "label": "Font style", "options": [{ "value": "normal", "label": "Normal" }, { "value": "italic", "label": "Italic" }], "default": "normal" },
    { "type": "select", "id": "btn_decoration", "label": "Text decoration", "options": [{ "value": "none", "label": "None" }, { "value": "underline", "label": "Underline" }, { "value": "line-through", "label": "Line-through" }], "default": "none" },

    { "type": "header", "content": "Button Style" },
    { "type": "range", "id": "btn_pv", "label": "Padding top / bottom (px)", "min": 4, "max": 200, "step": 2, "default": 16 },
    { "type": "range", "id": "btn_ph", "label": "Padding left / right (px)", "min": 8, "max": 200, "step": 2, "default": 32 },
    { "type": "range", "id": "btn_radius", "label": "Border radius (px)", "min": 0, "max": 200, "step": 2, "default": 6 },
    { "type": "range", "id": "btn_border_width", "label": "Border width (px)", "min": 0, "max": 20, "step": 1, "default": 0 },
    { "type": "range", "id": "btn_min_width", "label": "Min width (px)", "min": 0, "max": 1000, "step": 10, "default": 240 },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "section_pt", "label": "Padding top (px)", "min": 0, "max": 400, "step": 4, "default": 60 },
    { "type": "range", "id": "section_pb", "label": "Padding bottom (px)", "min": 0, "max": 400, "step": 4, "default": 0 },

