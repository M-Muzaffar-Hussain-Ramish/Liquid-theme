{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-facets.css' | asset_url | stylesheet_tag }}
<script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
  /* ---- Page wrapper ---- */
  .gwmf-col-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 32px 48px 48px;
  }

  /* ---- 30 / 70 layout ---- */
  .gwmf-col-layout {
    display: grid;
    grid-template-columns: 30% 1fr;
    gap: 40px;
    align-items: start;
  }

  /* ---- Filter sidebar (left 30%) ---- */
  .gwmf-col-filters-wrap {
    position: sticky;
    top: 90px;
  }

  /* Mobile toggle button — hidden on desktop */
  .gwmf-filter-toggle {
    display: none;
  }

  /* Override Dawn's facets styles so they fit our sidebar */
  .gwmf-col-filters-wrap .facets-wrapper {
    border: none;
    padding: 0;
    max-width: 100%;
  }

  .gwmf-col-filters-wrap .facets-container {
    padding: 0;
  }

  .gwmf-col-filters-wrap .facets-vertical .facets__form {
    position: static;
    top: auto;
    max-height: none;
    overflow: visible;
  }

  /* Filter group heading */
  .gwmf-col-filters-wrap .facets__summary {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #1a3a6e;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-bottom: 1px solid #e8edf4;
    padding: 10px 0;
  }

  /* Filter option labels */
  .gwmf-col-filters-wrap .facet-checkbox__text {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    color: #2a4a7a;
  }

  /* Active filter count badge */
  .gwmf-col-filters-wrap .facets__selected .badge {
    background: #1a5fbe;
    color: #fff;
  }

  /* ---- Product grid (right 70%) ---- */
  .gwmf-col-main { min-width: 0; }

  /* Strip Dawn's page-width padding inside our layout */
  .gwmf-col-main .page-width,
  .gwmf-col-main .collection.page-width,
  .gwmf-col-main .collection--empty.page-width {
    max-width: 100% !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  /* ---- Product Cards ---- */
  .gwmf-prodcard { display: flex; flex-direction: column; gap: 10px; text-align: center; }

  .gwmf-prodcard__img-wrap {
    position: relative; width: 100%; aspect-ratio: 1/1;
    border-radius: 12px; overflow: hidden; background: #f4f4f4; display: block;
  }
  .gwmf-prodcard__img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
  .gwmf-prodcard:hover .gwmf-prodcard__img-wrap img { transform: scale(1.04); }
  .gwmf-prodcard__img-wrap::after {
    content: ''; position: absolute; bottom: 0; right: 0;
    width: 0; height: 0; border-style: solid;
    border-width: 0 0 48px 48px;
    border-color: transparent transparent #ffffff transparent;
    filter: drop-shadow(-2px -2px 3px rgba(0,0,0,0.12)); z-index: 2;
  }
  .gwmf-prodcard__img-placeholder {
    width: 100%; height: 100%; display: flex; align-items: center;
    justify-content: center; background: #eef2f7; color: #b0bec5;
  }

  .gwmf-prodcard__title {
    font-family: 'Outfit', sans-serif; font-size: 13px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.04em; line-height: 1.3;
    color: #1a3a6e; text-decoration: none; display: block; margin: 0;
    transition: color 0.15s;
  }
  .gwmf-prodcard__title:hover { color: #0065ac; }

  .gwmf-prodcard__price { display: flex; align-items: center; justify-content: center; gap: 6px; flex-wrap: wrap; }
  .gwmf-prodcard__price-from { font-family: 'Outfit', sans-serif; font-size: 13px; font-weight: 500; color: #0065ac; }
  .gwmf-prodcard__price-sale { font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 700; color: #1a2e4a; }

  .gwmf-prodcard__badge {
    display: inline-block; font-family: 'Outfit', sans-serif;
    font-size: 10px; font-weight: 700; letter-spacing: 0.5px;
    text-transform: uppercase; padding: 2px 7px; border-radius: 4px; line-height: 1.6;
  }
  .gwmf-prodcard__badge--soldout { background: #9eaab8; color: #fff; }

  .gwmf-prodcard__swatches { display: flex; align-items: center; justify-content: center; gap: 6px; flex-wrap: wrap; }
  .gwmf-prodcard__swatch-thumb {
    display: inline-block; width: 36px; height: 36px; border-radius: 50px;
    overflow: hidden; border: 2px solid #fff; box-shadow: 0 0 0 1.5px #d0dce8;
    flex-shrink: 0; transition: box-shadow 0.18s;
  }
  .gwmf-prodcard__swatch-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .gwmf-prodcard__swatch-thumb:hover { box-shadow: 0 0 0 2px #1a5fbe; }

  /* ---- Category Nav ---- */
  .gwmf-cat-nav { margin-bottom: 4px; }

  .gwmf-cat-nav__heading {
    font-family: 'Outfit', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: #1a3a6e;
    margin: 0 0 8px;
    padding: 0;
  }

  .gwmf-cat-nav__list,
  .gwmf-cat-nav__sub {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .gwmf-cat-nav__item {
    border-bottom: 1px solid #e8edf4;
  }

  .gwmf-cat-nav__btn,
  .gwmf-cat-nav__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 11px 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #2a4a7a;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    text-decoration: none;
    transition: color 0.15s;
  }

  .gwmf-cat-nav__btn:hover,
  .gwmf-cat-nav__link:hover { color: #0065ac; }

  .gwmf-cat-nav__btn svg {
    width: 16px; height: 16px;
    stroke: currentColor; fill: none;
    stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .gwmf-cat-nav__btn.is-open svg { transform: rotate(180deg); }

  .gwmf-cat-nav__sub {
    display: none;
    padding: 2px 0 10px 12px;
    border-left: 3px solid #0065ac;
    margin-left: 2px;
  }

  .gwmf-cat-nav__sub.is-open { display: block; }

  .gwmf-cat-nav__child {
    display: block;
    padding: 7px 0 7px 8px;
    font-family: 'Outfit', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: #2a4a7a;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: color 0.15s, font-weight 0.1s;
  }

  .gwmf-cat-nav__child:hover,
  .gwmf-cat-nav__child.is-active {
    color: #0065ac;
    font-weight: 700;
  }

  .gwmf-cat-nav__item--active > .gwmf-cat-nav__btn,
  .gwmf-cat-nav__item--active > .gwmf-cat-nav__link {
    color: #0065ac;
    font-weight: 700;
  }

  .gwmf-cat-nav__divider {
    border: none;
    border-top: 2px solid #e8edf4;
    margin: 18px 0 16px;
  }

  .gwmf-filters-heading {
    font-family: 'Outfit', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: #1a3a6e;
    margin: 0 0 10px;
    padding: 0;
  }

  /* ---- Responsive: tablet ---- */
  @media screen and (max-width: 989px) {
    .gwmf-col-page { padding: 24px 32px 40px; }
    .gwmf-col-layout { grid-template-columns: 35% 1fr; gap: 28px; }
  }

  /* ---- Responsive: mobile ---- */
  @media screen and (max-width: 749px) {
    .gwmf-col-page { padding: 16px 16px 32px; }

    .gwmf-col-layout {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .gwmf-col-filters-wrap {
      position: static;
      margin-bottom: 4px;
    }

    /* Show mobile toggle */
    .gwmf-filter-toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 12px 16px;
      margin-bottom: 4px;
      background: #f4f8ff;
      border: 1.5px solid #d0dce8;
      border-radius: 12px;
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      font-weight: 700;
      color: #1a3a6e;
      cursor: pointer;
    }

    .gwmf-filter-toggle svg {
      width: 18px; height: 18px;
      stroke: currentColor; fill: none;
      stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
      transition: transform 0.2s;
      flex-shrink: 0;
    }

    .gwmf-filter-toggle.is-open svg { transform: rotate(180deg); }

    /* Filter body collapses on mobile */
    .gwmf-filter-body {
      display: none;
      padding: 12px 0 16px;
    }

    .gwmf-filter-body.is-open { display: block; }
  }
</style>

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
  {%- paginate collection.products by section.settings.products_per_page -%}

    <div class="gwmf-col-page">
      <div class="gwmf-col-layout">

        {%- comment -%} LEFT: Filters (30%) {%- endcomment -%}
        <div class="gwmf-col-filters-wrap">

          {%- comment -%} Categories Navigation {%- endcomment -%}
          {%- if section.settings.cat_menu != blank -%}
            {%- assign cat_list = linklists[section.settings.cat_menu] -%}
            {%- if cat_list.links.size > 0 -%}
              <nav class="gwmf-cat-nav" aria-label="Shop categories">
                <h3 class="gwmf-cat-nav__heading">Categories</h3>
                <ul class="gwmf-cat-nav__list">
                  {%- for link in cat_list.links -%}
                    {%- assign is_active = false -%}
                    {%- if link.active or link.child_active -%}{%- assign is_active = true -%}{%- endif -%}
                    <li class="gwmf-cat-nav__item{% if link.links.size > 0 %} gwmf-cat-nav__item--has-children{% endif %}{% if is_active %} gwmf-cat-nav__item--active{% endif %}">
                      {%- if link.links.size > 0 -%}
                        <button
                          class="gwmf-cat-nav__btn{% if is_active %} is-open{% endif %}"
                          aria-expanded="{{ is_active }}"
                          aria-controls="gwmf-cat-sub-{{ section.id }}-{{ forloop.index }}"
                        >
                          <span>{{ link.title }}</span>
                          <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                        </button>
                        <ul
                          class="gwmf-cat-nav__sub{% if is_active %} is-open{% endif %}"
                          id="gwmf-cat-sub-{{ section.id }}-{{ forloop.index }}"
                        >
                          {%- for child in link.links -%}
                            <li>
                              <a
                                href="{{ child.url }}"
                                class="gwmf-cat-nav__child{% if child.active %} is-active{% endif %}"
                              >{{ child.title }}</a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- else -%}
                        <a
                          href="{{ link.url }}"
                          class="gwmf-cat-nav__link{% if link.active %} is-active{% endif %}"
                        >
                          <span>{{ link.title }}</span>
                        </a>
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                </ul>
              </nav>
              <hr class="gwmf-cat-nav__divider">
            {%- endif -%}
          {%- endif -%}

          {%- comment -%} Mobile toggle — shown only on small screens via CSS {%- endcomment -%}
          <button class="gwmf-filter-toggle" id="gwmf-filter-toggle-{{ section.id }}" aria-expanded="false" aria-controls="gwmf-filter-body-{{ section.id }}">
            <span>Filters</span>
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
          </button>

          <div class="gwmf-filter-body" id="gwmf-filter-body-{{ section.id }}">
            <h3 class="gwmf-filters-heading">Filters</h3>
            <aside
              aria-labelledby="verticalTitle"
              class="facets-wrapper"
              id="main-collection-filters"
              data-id="{{ section.id }}"
            >
              {% render 'facets',
                results: collection,
                enable_filtering: section.settings.enable_filtering,
                enable_sorting: section.settings.enable_sorting,
                filter_type: 'vertical',
                paginate: paginate
              %}
            </aside>
          </div>

        </div>

        {%- comment -%} RIGHT: Products (70%) {%- endcomment -%}
        <div class="gwmf-col-main">

          <div
            class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            id="ProductGridContainer"
            {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}
          >
            {%- if collection.products.size == 0 -%}
              <div class="collection collection--empty page-width" id="product-grid" data-id="{{ section.id }}">
                <div class="loading-overlay gradient"></div>
                <div class="title-wrapper center">
                  <h2 class="title title--primary">
                    {{ 'sections.collection_template.empty' | t -}}
                    <br>
                    {{ 'sections.collection_template.use_fewer_filters_html' | t: link: collection.url, class: 'underlined-link link' }}
                  </h2>
                </div>
              </div>
            {%- else -%}
              <div class="collection">
                <div class="loading-overlay gradient"></div>
                <ul
                  id="product-grid"
                  data-id="{{ section.id }}"
                  class="
                    grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down
                    grid--{{ section.settings.columns_desktop }}-col-desktop
                    {% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %}
                  "
                >
                  {%- for product in collection.products -%}
                    {%- assign loading_attr = 'lazy' -%}
                    {%- if forloop.index <= 2 -%}{%- assign loading_attr = 'eager' -%}{%- endif -%}
                    <li
                      class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                      {% if settings.animations_reveal_on_scroll %}
                        data-cascade
                        style="--animation-order: {{ forloop.index }};"
                      {% endif %}
                    >
                      <div class="gwmf-prodcard">

                        <a href="{{ product.url }}" class="gwmf-prodcard__img-wrap">
                          {%- if product.featured_image != blank -%}
                            {%- assign img_alt = product.featured_image.alt | default: product.title | escape -%}
                            {{ product.featured_image | image_url: width: 600 | image_tag: alt: img_alt, loading: loading_attr, widths: '300, 400, 600' }}
                          {%- else -%}
                            <div class="gwmf-prodcard__img-placeholder">
                              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                            </div>
                          {%- endif -%}
                        </a>

                        <a href="{{ product.url }}" class="gwmf-prodcard__title">{{ product.title }}</a>

                        <div class="gwmf-prodcard__price">
                          {%- if product.available == false -%}
                            <span class="gwmf-prodcard__badge gwmf-prodcard__badge--soldout">Sold Out</span>
                          {%- endif -%}
                          <span class="gwmf-prodcard__price-from">FROM</span>
                          <span class="gwmf-prodcard__price-sale">{{ product.price_min | money }}</span>
                        </div>

                        {%- if section.settings.show_swatches -%}
                          {%- assign seen_img_ids = '' -%}
                          {%- assign swatch_count = 0 -%}
                          {%- assign has_swatches = false -%}
                          {%- for variant in product.variants -%}
                            {%- if variant.featured_image != blank -%}
                              {%- assign has_swatches = true -%}
                              {%- break -%}
                            {%- endif -%}
                          {%- endfor -%}
                          {%- if has_swatches -%}
                            <div class="gwmf-prodcard__swatches">
                              {%- for variant in product.variants -%}
                                {%- if variant.featured_image == blank -%}{%- continue -%}{%- endif -%}
                                {%- assign img_key = variant.featured_image.id | append: ',' -%}
                                {%- if seen_img_ids contains img_key -%}{%- continue -%}{%- endif -%}
                                {%- assign seen_img_ids = seen_img_ids | append: img_key -%}
                                {%- assign swatch_count = swatch_count | plus: 1 -%}
                                <a href="{{ product.url }}?variant={{ variant.id }}" class="gwmf-prodcard__swatch-thumb" title="{{ variant.title | escape }}">
                                  <img src="{{ variant.featured_image | image_url: width: 80 }}" alt="{{ variant.title | escape }}" width="36" height="36" loading="lazy">
                                </a>
                                {%- if swatch_count >= 6 -%}{%- break -%}{%- endif -%}
                              {%- endfor -%}
                            </div>
                          {%- endif -%}
                        {%- endif -%}

                      </div>
                    </li>
                  {%- endfor -%}
                </ul>

                {%- if paginate.pages > 1 -%}
                  {% render 'pagination', paginate: paginate, anchor: '' %}
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>

        </div>
      </div>
    </div>

  {%- endpaginate -%}
  {% if section.settings.image_shape == 'arch' %}
    {{ 'mask-arch.svg' | inline_asset_content }}
  {%- endif -%}
</div>

<script>
(function () {
  /* Mobile filter panel toggle */
  var toggle = document.getElementById('gwmf-filter-toggle-{{ section.id }}');
  var body   = document.getElementById('gwmf-filter-body-{{ section.id }}');
  if (toggle && body) {
    toggle.addEventListener('click', function () {
      var open = body.classList.toggle('is-open');
      toggle.classList.toggle('is-open', open);
      toggle.setAttribute('aria-expanded', open);
    });
  }

  /* Category nav accordion */
  document.querySelectorAll('.gwmf-cat-nav__btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var subId = this.getAttribute('aria-controls');
      var sub   = subId ? document.getElementById(subId) : this.nextElementSibling;
      if (!sub) return;
      var open = sub.classList.toggle('is-open');
      this.classList.toggle('is-open', open);
      this.setAttribute('aria-expanded', open);
    });
  });
})();
</script>

{% schema %}
{
  "name": "t:sections.main-collection-product-grid.name",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Categories Sidebar"
    },
    {
      "type": "link_list",
      "id": "cat_menu",
      "label": "Categories navigation menu",
      "info": "Create a navigation menu in Shopify Admin > Navigation with your collection links (supports 2 levels)."
    },
    {
      "type": "header",
      "content": "Product Badges"
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "Show SALE badge on discounted products",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "Show color swatches",
      "default": true
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16,
      "label": "t:sections.main-collection-product-grid.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "t:sections.main-collection-product-grid.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.main-collection-product-grid.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__2.label"
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__3.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__3.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.main-collection-product-grid.settings.image_ratio.label"
    },
    {
      "type": "select",
      "id": "image_shape",
      "options": [
        {
          "value": "default",
          "label": "t:sections.all.image_shape.options__1.label"
        },
        {
          "value": "arch",
          "label": "t:sections.all.image_shape.options__2.label"
