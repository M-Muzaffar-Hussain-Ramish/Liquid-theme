{%- style -%}
  #shopify-section-{{ section.id }} {
    width: 100% !important;
    max-width: 100% !important;
    background-color: {{ section.settings.bg_color }};
  }
{%- endstyle -%}

<style>
  .gwmf-trust {
    width: 100%;
    background-color: {{ section.settings.bg_color }};
    padding: 0px 0px;
  }

  .gwmf-trust__card {
    max-width: 1200px;
    margin: 0 auto;
    background: {{ section.settings.card_bg_color }};
    border-radius: 24px;
    padding: 60px;
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr;
    gap: 50px;
    align-items: center;
  }

  /* ---- LEFT COLUMN ---- */
  .gwmf-trust__main-icon {
    font-size: 34px;
    color: {{ section.settings.main_heading_color }};
    font-weight: bold;
    line-height: 1;
    margin-bottom: 20px;
    display: block;
  }

  .gwmf-trust__main-icon img {
    width: 52px;
    height: auto;
    display: block;
  }

  .gwmf-trust__main-icon svg {
    display: block;
  }

  .gwmf-trust__main-heading {
    font-family: 'Dimbo', 'Outfit', sans-serif;
    font-size: clamp(28px, 3vw, 48px);
    font-weight: 800;
    line-height: 1.1;
    color: {{ section.settings.main_heading_color }};
    margin: 0 0 16px;
    white-space: pre-line;
  }

  .gwmf-trust__main-body {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    line-height: 1.8;
    color: {{ section.settings.main_body_color }};
    margin: 0;
  }

  /* ---- FEATURE COLUMNS ---- */
  .gwmf-trust__item-icon {
    width: 90px;
    height: 90px;
    object-fit: contain;
    display: block;
    margin-bottom: 22px;
  }

  .gwmf-trust__item-icon-svg {
    width: 90px;
    height: 90px;
    margin-bottom: 22px;
    display: block;
  }

  .gwmf-trust__item-heading {
    font-family: 'Outfit', sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: {{ section.settings.feature_heading_color }};
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .gwmf-trust__item-body {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    line-height: 1.8;
    color: {{ section.settings.feature_body_color }};
    margin: 0;
    white-space: pre-line;
  }

  /* ---- ANIMATIONS ---- */
  .gwmf-trust__col {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .gwmf-trust.is-visible .gwmf-trust__col:nth-child(1) {
    opacity: 1; transform: translateY(0); transition-delay: 0s;
  }
  .gwmf-trust.is-visible .gwmf-trust__col:nth-child(2) {
    opacity: 1; transform: translateY(0); transition-delay: 0.15s;
  }
  .gwmf-trust.is-visible .gwmf-trust__col:nth-child(3) {
    opacity: 1; transform: translateY(0); transition-delay: 0.3s;
  }

  /* ---- RESPONSIVE ---- */
  @media screen and (max-width: 989px) {
    .gwmf-trust__card {
      grid-template-columns: 1fr;
      padding: 40px 28px;
      gap: 40px;
      text-align: center;
    }
    .gwmf-trust__item-icon,
    .gwmf-trust__item-icon-svg {
      margin-left: auto;
      margin-right: auto;
    }
    .gwmf-trust__main-icon {
      display: flex;
      justify-content: center;
    }
    .gwmf-trust__main-heading {
      font-size: clamp(28px, 8vw, 40px);
    }
  }

  @media screen and (max-width: 749px) {
    .gwmf-trust {
      padding: 40px 14px;
    }
    .gwmf-trust__card {
      padding: 36px 20px;
      gap: 36px;
      border-radius: 18px;
    }
    .gwmf-trust__item-heading {
      font-size: 20px;
    }
  }

  @media screen and (max-width: 480px) {
    .gwmf-trust {
      padding: 32px 10px;
    }
    .gwmf-trust__card {
      padding: 28px 16px;
      border-radius: 14px;
    }
  }
</style>

<section class="gwmf-trust" id="shopify-section-{{ section.id }}">
  <div class="gwmf-trust__card">
    {%- for block in section.blocks -%}
      {%- if block.settings.style == 'main' -%}
        {%- comment -%} LEFT COLUMN {%- endcomment -%}
        <div class="gwmf-trust__col" {{ block.shopify_attributes }}>
          {%- comment -%} Icon: uploaded image → default SVG flag {%- endcomment -%}
          <span class="gwmf-trust__main-icon">
            {%- if block.settings.icon != blank -%}
              {%- assign icon_alt = block.settings.icon.alt | default: '' | escape -%}
              {{ block.settings.icon | image_url: width: 160 | image_tag: alt: icon_alt, loading: 'lazy' }}
            {%- elsif block.settings.default_icon == 'flag' -%}
              <svg width="52" height="36" viewBox="0 0 52 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="52" height="36" rx="3" fill="#B22234"/>
                <rect y="2.77" width="52" height="2.77" fill="#FFF"/>
                <rect y="8.31" width="52" height="2.77" fill="#FFF"/>
                <rect y="13.85" width="52" height="2.77" fill="#FFF"/>
                <rect y="19.38" width="52" height="2.77" fill="#FFF"/>
                <rect y="24.92" width="52" height="2.77" fill="#FFF"/>
                <rect y="30.46" width="52" height="2.77" fill="#FFF"/>
                <rect width="20.8" height="19.38" fill="#3C3B6E"/>
                <circle cx="2.6" cy="2.4" r="1.1" fill="#FFF"/>
                <circle cx="6.5" cy="2.4" r="1.1" fill="#FFF"/>
                <circle cx="10.4" cy="2.4" r="1.1" fill="#FFF"/>
                <circle cx="14.3" cy="2.4" r="1.1" fill="#FFF"/>
                <circle cx="18.2" cy="2.4" r="1.1" fill="#FFF"/>
                <circle cx="4.55" cy="5.55" r="1.1" fill="#FFF"/>
                <circle cx="8.45" cy="5.55" r="1.1" fill="#FFF"/>
                <circle cx="12.35" cy="5.55" r="1.1" fill="#FFF"/>
                <circle cx="16.25" cy="5.55" r="1.1" fill="#FFF"/>
                <circle cx="2.6" cy="8.7" r="1.1" fill="#FFF"/>
                <circle cx="6.5" cy="8.7" r="1.1" fill="#FFF"/>
                <circle cx="10.4" cy="8.7" r="1.1" fill="#FFF"/>
                <circle cx="14.3" cy="8.7" r="1.1" fill="#FFF"/>
                <circle cx="18.2" cy="8.7" r="1.1" fill="#FFF"/>
                <circle cx="4.55" cy="11.85" r="1.1" fill="#FFF"/>
                <circle cx="8.45" cy="11.85" r="1.1" fill="#FFF"/>
                <circle cx="12.35" cy="11.85" r="1.1" fill="#FFF"/>
                <circle cx="16.25" cy="11.85" r="1.1" fill="#FFF"/>
                <circle cx="2.6" cy="15.0" r="1.1" fill="#FFF"/>
                <circle cx="6.5" cy="15.0" r="1.1" fill="#FFF"/>
                <circle cx="10.4" cy="15.0" r="1.1" fill="#FFF"/>
                <circle cx="14.3" cy="15.0" r="1.1" fill="#FFF"/>
                <circle cx="18.2" cy="15.0" r="1.1" fill="#FFF"/>
                <circle cx="4.55" cy="18.15" r="1.1" fill="#FFF"/>
                <circle cx="8.45" cy="18.15" r="1.1" fill="#FFF"/>
                <circle cx="12.35" cy="18.15" r="1.1" fill="#FFF"/>
                <circle cx="16.25" cy="18.15" r="1.1" fill="#FFF"/>
              </svg>
            {%- elsif block.settings.icon_text != blank -%}
              {{ block.settings.icon_text }}
            {%- endif -%}
          </span>

          {%- if block.settings.heading != blank -%}
            <p class="gwmf-trust__main-heading">{{- block.settings.heading -}}</p>
          {%- endif -%}

          {%- if block.settings.body != blank -%}
            <p class="gwmf-trust__main-body">{{- block.settings.body -}}</p>
          {%- endif -%}
        </div>

      {%- else -%}
        {%- comment -%} FEATURE COLUMNS {%- endcomment -%}
        <div class="gwmf-trust__col" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            {%- assign icon_alt = block.settings.icon.alt | default: '' | escape -%}
            {{
              block.settings.icon
              | image_url: width: 180
              | image_tag: alt: icon_alt, loading: 'lazy', class: 'gwmf-trust__item-icon'
            }}

          {%- elsif block.settings.default_icon == 'production' -%}
            <svg class="gwmf-trust__item-icon-svg" viewBox="0 0 90 90" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="9" y="42" width="72" height="27" rx="7" fill="#d4e4f7" stroke="#1a5fbe" stroke-width="2.5"/>
              <rect x="20" y="22" width="50" height="25" rx="4" fill="white" stroke="#1a5fbe" stroke-width="2"/>
              <circle cx="30" cy="30" r="2.2" fill="#1a5fbe"/>
              <circle cx="38" cy="30" r="2.2" fill="#1a5fbe"/>
              <circle cx="46" cy="30" r="2.2" fill="#1a5fbe"/>
              <circle cx="54" cy="30" r="2.2" fill="#1a5fbe"/>
              <circle cx="62" cy="30" r="2.2" fill="#1a5fbe"/>
              <circle cx="30" cy="38" r="2.2" fill="#1a5fbe"/>
              <circle cx="38" cy="38" r="2.2" fill="#1a5fbe"/>
              <circle cx="46" cy="38" r="2.2" fill="#1a5fbe"/>
              <circle cx="54" cy="38" r="2.2" fill="#1a5fbe"/>
              <rect x="20" y="47" width="50" height="3.5" rx="1.75" fill="#1a5fbe" opacity="0.35"/>
              <path d="M77 18 L78.5 13 L80 18 L85 19.5 L80 21 L78.5 26 L77 21 L72 19.5 Z" fill="#1a5fbe" opacity="0.6"/>
              <circle cx="11" cy="34" r="2.8" fill="#1a5fbe" opacity="0.3"/>
            </svg>

          {%- elsif block.settings.default_icon == 'shipping' -%}
            <svg class="gwmf-trust__item-icon-svg" viewBox="0 0 90 90" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M45 11 C25 11 13 27 13 38 L45 38 L77 38 C77 27 65 11 45 11 Z" fill="#d4e4f7" stroke="#1a5fbe" stroke-width="2"/>
              <line x1="45" y1="38" x2="45" y2="11" stroke="#1a5fbe" stroke-width="1.5" opacity="0.35"/>
              <line x1="20" y1="38" x2="33" y2="58" stroke="#1a5fbe" stroke-width="2"/>
              <line x1="70" y1="38" x2="57" y2="58" stroke="#1a5fbe" stroke-width="2"/>
              <line x1="45" y1="38" x2="45" y2="58" stroke="#1a5fbe" stroke-width="2"/>
              <rect x="30" y="58" width="30" height="22" rx="4" fill="#1a5fbe"/>
              <line x1="45" y1="58" x2="45" y2="80" stroke="white" stroke-width="1.5" opacity="0.5"/>
              <line x1="30" y1="67" x2="60" y2="67" stroke="white" stroke-width="1.5" opacity="0.5"/>
            </svg>
          {%- endif -%}

          {%- if block.settings.heading != blank -%}
            <h3 class="gwmf-trust__item-heading">{{ block.settings.heading }}</h3>
          {%- endif -%}

          {%- if block.settings.body != blank -%}
            <p class="gwmf-trust__item-body">{{- block.settings.body -}}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<script>
  (function () {
    var sec = document.querySelector('#shopify-section-{{ section.id }} .gwmf-trust');
    if (!sec) return;
    var io = new IntersectionObserver(
      function (entries) {
        if (entries[0].isIntersecting) {
          sec.classList.add('is-visible');
          io.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    io.observe(sec);
  })();
</script>

{% schema %}
{
  "name": "Trust Strip",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background color",
      "default": "#eef3f6"
    },
    {
      "type": "color",
      "id": "main_heading_color",
      "label": "Left column heading color",
      "default": "#0b4f94"
    },
    {
      "type": "color",
      "id": "main_body_color",
      "label": "Left column body color",
      "default": "#59697a"
    },
    {
      "type": "color",
      "id": "feature_heading_color",
      "label": "Feature column heading color",
      "default": "#0b4f94"
    },
    {
      "type": "color",
      "id": "feature_body_color",
      "label": "Feature column body color",
      "default": "#59697a"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "select",
          "id": "style",
          "label": "Column style",
          "options": [
            { "value": "main", "label": "Main (left — large heading)" },
            { "value": "feature", "label": "Feature (right — icon + heading)" }
          ],
          "default": "feature"
        },
        {
          "type": "select",
          "id": "default_icon",
          "label": "Default icon (shown when no image uploaded)",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "flag", "label": "US Flag" },
            { "value": "production", "label": "Production / Printer" },
            { "value": "shipping", "label": "Shipping / Delivery" }
          ],
          "default": "none"
        },
        {
          "type": "text",
          "id": "icon_text",
          "label": "Icon text / emoji (Main style fallback)"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image (overrides default icon)"
        },
        {
          "type": "textarea",
          "id": "heading",
          "label": "Heading",
          "default": "We Print It Right.\nWe Ship It Fast."
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body text",
          "default": "Premium materials. Handmade in the U.S.A.\nDelivered worldwide."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Strip",
      "blocks": [
        {
          "type": "column",
          "settings": {
            "style": "main",
            "default_icon": "flag",
            "heading": "We Print It Right.\nWe Ship It Fast.",
            "body": "Premium materials. Handmade in the U.S.A.\nDelivered worldwide."
          }
        },
        {
          "type": "column",
          "settings": {
            "style": "feature",
            "default_icon": "production",
            "heading": "Production Time",
            "body": "Gift Wrap: Ships in 3 business days\nParty Items: Ships in 5 business days\nAll Products: Custom-made, not mass-produced"
          }
        },
        {
          "type": "column",
          "settings": {
            "style": "feature",
            "default_icon": "shipping",
            "heading": "Shipping Time",
            "body": "Free Standard Shipping: 7-10 business days\nUPS Ground (Fastest): 3-6 business days\nWe Ship Worldwide"
          }
        }
      ]
    }
  ]
}
{% endschema %}
