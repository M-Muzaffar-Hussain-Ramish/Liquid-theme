{%- style -%}
  #shopify-section-{{ section.id }} {
    width: 100% !important;
    max-width: 100% !important;
    /* Colors */
    --su-bg:           {{ section.settings.bg_color }};
    --su-eyebrow:      {{ section.settings.eyebrow_color }};
    --su-heading:      {{ section.settings.heading_color }};
    --su-subtext:      {{ section.settings.subtext_color }};
    --su-btn:          {{ section.settings.btn_color }};
    --su-btn-text:     {{ section.settings.btn_text_color }};
    --su-btn-bc:       {{ section.settings.btn_border_color }};
    --su-input-bg:     {{ section.settings.input_bg_color }};
    --su-input-text:   {{ section.settings.input_text_color }};
    /* Eyebrow typography */
    --su-eye-font:       {{ section.settings.eye_font }};
    --su-eye-size:       {{ section.settings.eye_size }}px;
    --su-eye-weight:     {{ section.settings.eye_weight }};
    --su-eye-transform:  {{ section.settings.eye_transform }};
    --su-eye-ls:         {{ section.settings.eye_ls | times: 0.1 }}px;
    --su-eye-lh:         {{ section.settings.eye_lh | divided_by: 10.0 }};
    --su-eye-style:      {{ section.settings.eye_style }};
    --su-eye-decoration: {{ section.settings.eye_decoration }};
    /* Heading typography */
    --su-head-font:       {{ section.settings.head_font }};
    --su-head-size:       {{ section.settings.head_size }}px;
    --su-head-weight:     {{ section.settings.head_weight }};
    --su-head-transform:  {{ section.settings.head_transform }};
    --su-head-ls:         {{ section.settings.head_ls | times: 0.1 }}px;
    --su-head-lh:         {{ section.settings.head_lh | divided_by: 10.0 }};
    --su-head-style:      {{ section.settings.head_style }};
    --su-head-decoration: {{ section.settings.head_decoration }};
    /* Subtext typography */
    --su-sub-font:       {{ section.settings.sub_font }};
    --su-sub-size:       {{ section.settings.sub_size }}px;
    --su-sub-weight:     {{ section.settings.sub_weight }};
    --su-sub-transform:  {{ section.settings.sub_transform }};
    --su-sub-ls:         {{ section.settings.sub_ls | times: 0.1 }}px;
    --su-sub-lh:         {{ section.settings.sub_lh | divided_by: 10.0 }};
    --su-sub-style:      {{ section.settings.sub_style }};
    --su-sub-decoration: {{ section.settings.sub_decoration }};
    /* Button typography */
    --su-btn-font:       {{ section.settings.btn_font }};
    --su-btn-size:       {{ section.settings.btn_size }}px;
    --su-btn-weight:     {{ section.settings.btn_weight }};
    --su-btn-transform:  {{ section.settings.btn_transform }};
    --su-btn-ls:         {{ section.settings.btn_ls | times: 0.1 }}px;
    --su-btn-lh:         {{ section.settings.btn_lh | divided_by: 10.0 }};
    --su-btn-style:      {{ section.settings.btn_style }};
    --su-btn-decoration: {{ section.settings.btn_decoration }};
    /* Button style */
    --su-btn-pv:     {{ section.settings.btn_pv }}px;
    --su-btn-ph:     {{ section.settings.btn_ph }}px;
    --su-btn-radius: {{ section.settings.btn_radius }}px;
    --su-btn-bw:     {{ section.settings.btn_bw }}px;
    --su-btn-minw:   {{ section.settings.btn_minw }}px;
    /* Layout */
    --su-form-maxw: {{ section.settings.form_max_width }}px;
    --su-pt:        {{ section.settings.section_pt }}px;
    --su-pb:        {{ section.settings.section_pb }}px;
    /* Alignment & Container */
    --su-align: {{ section.settings.content_align }};
    --su-maxw:  {{ section.settings.content_max_width }}px;
    --su-pl:    {{ section.settings.section_pl }}px;
    --su-pr:    {{ section.settings.section_pr }}px;
    --su-minh:  {{ section.settings.section_minh }}px;
    background-color: var(--su-bg);
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --su-eye-size:  {{ section.settings.eye_size_mobile }}px;
      --su-head-size: {{ section.settings.head_size_mobile }}px;
      --su-sub-size:  {{ section.settings.sub_size_mobile }}px;
      --su-btn-size:  {{ section.settings.btn_size_mobile }}px;
      --su-pt: {{ section.settings.section_pt_mobile }}px;
      --su-pb: {{ section.settings.section_pb_mobile }}px;
      --su-pl: {{ section.settings.section_pl_mobile }}px;
      --su-pr: {{ section.settings.section_pr_mobile }}px;
    }
  }
{%- endstyle -%}

<style>
  .gwmf-signup { position: relative; width: 100%; background-color: var(--su-bg); overflow: hidden; }

  .gwmf-signup__wave-top { position: absolute; top: -1px; left: 0; width: 100%; line-height: 0; pointer-events: none; z-index: 1; }
  .gwmf-signup__wave-top svg { display: block; width: 100%; height: 80px; }

  .gwmf-signup__inner {
    position: relative; z-index: 2;
    max-width: var(--su-maxw); margin: 0 auto;
    padding: var(--su-pt) var(--su-pr) var(--su-pb) var(--su-pl);
    min-height: var(--su-minh);
    text-align: var(--su-align);
    display: flex; flex-direction: column; align-items: center; gap: 14px;
  }

  .gwmf-signup__eyebrow {
    font-family: var(--su-eye-font);
    font-size: var(--su-eye-size);
    font-weight: var(--su-eye-weight);
    text-transform: var(--su-eye-transform);
    letter-spacing: var(--su-eye-ls);
    line-height: var(--su-eye-lh);
    font-style: var(--su-eye-style);
    text-decoration: var(--su-eye-decoration);
    color: var(--su-eyebrow);
    margin: 0;
  }

  .gwmf-signup__heading {
    font-family: var(--su-head-font);
    font-size: var(--su-head-size);
    font-weight: var(--su-head-weight);
    text-transform: var(--su-head-transform);
    letter-spacing: var(--su-head-ls);
    line-height: var(--su-head-lh);
    font-style: var(--su-head-style);
    text-decoration: var(--su-head-decoration);
    color: var(--su-heading);
    margin: 0;
  }

  .gwmf-signup__subtext {
    font-family: var(--su-sub-font);
    font-size: var(--su-sub-size);
    font-weight: var(--su-sub-weight);
    text-transform: var(--su-sub-transform);
    letter-spacing: var(--su-sub-ls);
    line-height: var(--su-sub-lh);
    font-style: var(--su-sub-style);
    text-decoration: var(--su-sub-decoration);
    color: var(--su-subtext);
    margin: 0 0 8px;
  }

  .gwmf-signup__form {
    display: flex; align-items: stretch; gap: 0;
    width: 100%; max-width: var(--su-form-maxw);
    margin-top: 10px;
  }

  .gwmf-signup__input {
    flex: 1;
    padding: var(--su-btn-pv) var(--su-btn-ph);
    font-family: var(--su-btn-font);
    font-size: var(--su-btn-size);
    font-weight: var(--su-btn-weight);
    letter-spacing: var(--su-btn-ls);
    text-transform: var(--su-btn-transform);
    color: var(--su-input-text);
    background: var(--su-input-bg);
    border: none;
    border-radius: var(--su-btn-radius) 0 0 var(--su-btn-radius);
    outline: none;
    min-width: 0;
  }

  .gwmf-signup__input::placeholder { color: #8a9ab0; }

  .gwmf-signup__btn {
    flex-shrink: 0;
    padding: var(--su-btn-pv) var(--su-btn-ph);
    background: var(--su-btn);
    color: var(--su-btn-text);
    font-family: var(--su-btn-font);
    font-size: var(--su-btn-size);
    font-weight: var(--su-btn-weight);
    text-transform: var(--su-btn-transform);
    letter-spacing: var(--su-btn-ls);
    line-height: var(--su-btn-lh);
    font-style: var(--su-btn-style);
    text-decoration: var(--su-btn-decoration);
    border: var(--su-btn-bw) solid var(--su-btn-bc);
    border-radius: 0 var(--su-btn-radius) var(--su-btn-radius) 0;
    min-width: var(--su-btn-minw);
    cursor: pointer;
    transition: filter 0.2s, transform 0.15s;
    white-space: nowrap;
  }

  .gwmf-signup__btn:hover { filter: brightness(1.1); transform: translateY(-1px); }

  .gwmf-signup__msg {
    font-family: 'Outfit', sans-serif;
    font-size: 14px; font-weight: 600;
    color: #ffffff; margin: 4px 0 0; min-height: 20px;
  }

  .gwmf-signup__eyebrow,
  .gwmf-signup__heading,
  .gwmf-signup__subtext,
  .gwmf-signup__form { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }

  .gwmf-signup.is-visible .gwmf-signup__eyebrow { opacity: 1; transform: translateY(0); transition-delay: 0s; }
  .gwmf-signup.is-visible .gwmf-signup__heading  { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
  .gwmf-signup.is-visible .gwmf-signup__subtext  { opacity: 1; transform: translateY(0); transition-delay: 0.18s; }
  .gwmf-signup.is-visible .gwmf-signup__form     { opacity: 1; transform: translateY(0); transition-delay: 0.28s; }

  @media screen and (max-width: 989px) {
    .gwmf-signup__inner { padding: calc(var(--su-pt) * 0.88) calc(var(--su-pr) * 0.75) calc(var(--su-pb) * 0.88) calc(var(--su-pl) * 0.75); }
    .gwmf-signup__wave-top svg { height: 56px; }
  }
  @media screen and (max-width: 749px) {
    .gwmf-signup__inner { padding: var(--su-pt) var(--su-pr) var(--su-pb) var(--su-pl); gap: 12px; }
    .gwmf-signup__wave-top svg { height: 40px; }
    .gwmf-signup__form { flex-direction: column; gap: 10px; }
    .gwmf-signup__input { border-radius: var(--su-btn-radius); text-align: center; }
    .gwmf-signup__btn { border-radius: var(--su-btn-radius); }
  }
  @media screen and (max-width: 480px) {
    .gwmf-signup__inner { padding: var(--su-pt) var(--su-pr) var(--su-pb) var(--su-pl); }
  }
</style>

<section class="gwmf-signup" id="shopify-section-{{ section.id }}">
  <div class="gwmf-signup__wave-top">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,0 C480,80 960,80 1440,0 Z" fill="#ffffff"/>
    </svg>
  </div>

  <div class="gwmf-signup__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="gwmf-signup__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="gwmf-signup__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="gwmf-signup__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {%- form 'customer', id: 'gwmf-signup-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="gwmf-signup__form">
        <input
          class="gwmf-signup__input"
          type="email"
          name="contact[email]"
          id="gwmf-signup-email"
          value="{{ form.email }}"
          placeholder="{{ section.settings.input_placeholder }}"
          autocomplete="email"
          required
          aria-label="{{ section.settings.input_placeholder }}"
        >
        <button type="submit" class="gwmf-signup__btn">
          {{ section.settings.btn_label }}
        </button>
      </div>
      {%- if form.posted_successfully? -%}
        <p class="gwmf-signup__msg">{{ section.settings.success_msg }}</p>
      {%- elsif form.errors -%}
        <p class="gwmf-signup__msg">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

<script>
  (function () {
    var sec = document.querySelector('#shopify-section-{{ section.id }} .gwmf-signup');
    if (!sec) return;
    var io = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) { sec.classList.add('is-visible'); io.disconnect(); }
    }, { threshold: 0.1 });
    io.observe(sec);
  })();
</script>

{% schema %}
{
  "name": "Email Signup",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color",          "label": "Background",         "default": "#1a6fcc" },
    { "type": "color", "id": "eyebrow_color",      "label": "Eyebrow color",      "default": "#ffffff" },
    { "type": "color", "id": "heading_color",      "label": "Heading color",      "default": "#ffffff" },
    { "type": "color", "id": "subtext_color",      "label": "Subtext color",      "default": "#cde3f7" },
    { "type": "color", "id": "btn_color",          "label": "Button background",  "default": "#e8430a" },
    { "type": "color", "id": "btn_text_color",     "label": "Button text",        "default": "#ffffff" },
    { "type": "color", "id": "btn_border_color",   "label": "Button border",      "default": "#e8430a" },
