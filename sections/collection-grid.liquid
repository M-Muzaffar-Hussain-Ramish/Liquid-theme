{%- style -%}
  #shopify-section-{{ section.id }} {
    --grid-bg:           {{ section.settings.bg_color }};
    --grid-heading:      {{ section.settings.heading_color }};
    --grid-subtitle:     {{ section.settings.subtitle_color }};
    --grid-pill-border:  {{ section.settings.pill_border_color }};
    --grid-pill-text:    {{ section.settings.pill_text_color }};
    --grid-pill-active:  {{ section.settings.pill_active_color }};
    --grid-price:        {{ section.settings.price_color }};
    --grid-btn-bg:       {{ section.settings.btn_bg_color }};
    --grid-btn-text:     {{ section.settings.btn_text_color }};
    background-color: var(--grid-bg);
  }
{%- endstyle -%}

<style>
  .gwmf-colgrid {
    width: 100%;
  }

  .gwmf-colgrid__inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 64px 48px 72px;
    text-align: center;
  }

  .gwmf-colgrid__heading {
    font-family: 'Dimbo', 'Outfit', sans-serif;
    font-size: clamp(48px, 6vw, 80px);
    font-weight: 800;
    color: var(--grid-heading);
    line-height: 1;
    margin: 0 0 10px;
  }

  .gwmf-colgrid__subtitle {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--grid-subtitle);
    margin: 0 0 36px;
    letter-spacing: 0.3px;
  }

  /* ---- TAG FILTER BAR ---- */
  .gwmf-colgrid__filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 40px;
  }

  .gwmf-filter__tag {
    font-family: 'Outfit', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    padding: 10px 18px;
    border-radius: 50px;
    border: 2px solid var(--grid-pill-border);
    background: transparent;
    color: var(--grid-pill-text);
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .gwmf-filter__tag:hover {
    border-color: var(--grid-pill-active);
    color: var(--grid-pill-active);
  }

  .gwmf-filter__tag.is-active {
    background: var(--grid-pill-active);
    border-color: var(--grid-pill-active);
    color: #fff;
  }

  /* ---- PRODUCT GRID ---- */
  .gwmf-colgrid__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
    text-align: left;
  }

  .gwmf-prodcard {
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .gwmf-prodcard.is-hidden {
    display: none;
  }

  /* Image with curl */
  .gwmf-prodcard__img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    overflow: hidden;
    background: #f4f4f4;
  }

  .gwmf-prodcard__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .gwmf-prodcard:hover .gwmf-prodcard__img-wrap img {
    transform: scale(1.04);
  }

  /* Page curl at bottom-right */
  .gwmf-prodcard__img-wrap::after {
    content: '';
    position: absolute;
    bottom: 0;
    right: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 0 48px 48px;
    border-color: transparent transparent #ffffff transparent;
    filter: drop-shadow(-2px -2px 3px rgba(0,0,0,0.12));
    z-index: 2;
  }

  .gwmf-prodcard__img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #eef2f7;
    color: #b0bec5;
  }

  /* Product info */
  .gwmf-prodcard__title {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 800;
    color: #1a1a1a;
    text-transform: uppercase;
    line-height: 1.3;
    margin: 0;
    text-decoration: none;
    display: block;
  }

  .gwmf-prodcard__title:hover {
    color: #1a5fbe;
  }

  .gwmf-prodcard__stars {
    color: #f5a623;
    font-size: 14px;
    letter-spacing: 1px;
    line-height: 1;
  }

  .gwmf-prodcard__price {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .gwmf-prodcard__price-sale {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--grid-price);
  }

  .gwmf-prodcard__price-compare {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #9eaab8;
    text-decoration: line-through;
  }

  /* Color swatches */
  .gwmf-prodcard__swatches {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .gwmf-prodcard__swatch {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid #fff;
    box-shadow: 0 0 0 1.5px #d0dce8;
    display: inline-block;
  }

  .gwmf-prodcard__swatch-more {
    font-family: 'Outfit', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: #6a7f96;
  }

  /* SEE ALL button */
  .gwmf-colgrid__cta {
    margin-top: 48px;
  }

  .gwmf-colgrid__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 56px;
    background: var(--grid-btn-bg);
    color: var(--grid-btn-text);
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    text-decoration: none;
    border-radius: 8px;
    transition: filter 0.2s, transform 0.15s;
  }

  .gwmf-colgrid__btn:hover {
    filter: brightness(0.85);
    transform: translateY(-2px);
  }

  /* ---- ANIMATIONS ---- */
  .gwmf-colgrid__heading,
  .gwmf-colgrid__subtitle,
  .gwmf-colgrid__filters,
  .gwmf-prodcard,
  .gwmf-colgrid__cta {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  .gwmf-colgrid.is-visible .gwmf-colgrid__heading {
    opacity: 1; transform: translateY(0); transition-delay: 0s;
  }
  .gwmf-colgrid.is-visible .gwmf-colgrid__subtitle {
    opacity: 1; transform: translateY(0); transition-delay: 0.08s;
  }
  .gwmf-colgrid.is-visible .gwmf-colgrid__filters {
    opacity: 1; transform: translateY(0); transition-delay: 0.16s;
  }
  .gwmf-colgrid.is-visible .gwmf-prodcard:nth-child(1) {
    opacity: 1; transform: translateY(0); transition-delay: 0.24s;
  }
  .gwmf-colgrid.is-visible .gwmf-prodcard:nth-child(2) {
    opacity: 1; transform: translateY(0); transition-delay: 0.34s;
  }
  .gwmf-colgrid.is-visible .gwmf-prodcard:nth-child(3) {
    opacity: 1; transform: translateY(0); transition-delay: 0.44s;
  }
  .gwmf-colgrid.is-visible .gwmf-prodcard:nth-child(4) {
    opacity: 1; transform: translateY(0); transition-delay: 0.54s;
  }
  .gwmf-colgrid.is-visible .gwmf-prodcard:nth-child(n+5) {
    opacity: 1; transform: translateY(0); transition-delay: 0.6s;
  }
  .gwmf-colgrid.is-visible .gwmf-colgrid__cta {
    opacity: 1; transform: translateY(0); transition-delay: 0.65s;
  }

  /* ---- RESPONSIVE ---- */
  @media screen and (max-width: 1199px) {
    .gwmf-colgrid__inner {
      padding: 52px 32px 60px;
    }
    .gwmf-colgrid__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }
  }

  @media screen and (max-width: 989px) {
    .gwmf-colgrid__inner {
      padding: 44px 24px 52px;
    }
    .gwmf-colgrid__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
    }
    .gwmf-filter__tag {
      font-size: 11px;
      padding: 8px 14px;
    }
  }

  @media screen and (max-width: 749px) {
    .gwmf-colgrid__inner {
      padding: 36px 16px 44px;
    }
    .gwmf-colgrid__heading {
      font-size: clamp(36px, 12vw, 56px);
    }
    /* Make filter pills scroll horizontally on mobile */
    .gwmf-colgrid__filters {
      flex-wrap: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
      justify-content: flex-start;
      padding-bottom: 4px;
      margin: 0 -16px 40px;
      padding-left: 16px;
      padding-right: 16px;
    }
    .gwmf-colgrid__filters::-webkit-scrollbar { display: none; }
    .gwmf-filter__tag { flex-shrink: 0; }
    .gwmf-colgrid__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
    .gwmf-prodcard__title {
      font-size: 12px;
    }
    .gwmf-prodcard__price-sale,
    .gwmf-prodcard__price-compare {
      font-size: 13px;
    }
    .gwmf-colgrid__btn {
      padding: 14px 40px;
      font-size: 13px;
    }
  }

  @media screen and (max-width: 480px) {
    .gwmf-colgrid__grid {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .gwmf-filter__tag {
      font-size: 10px;
      padding: 7px 11px;
    }
  }
</style>

{%- liquid
  assign col = collections[section.settings.collection]
  assign limit = section.settings.products_to_show | default: 8
-%}

<div class="gwmf-colgrid" id="shopify-section-{{ section.id }}">
  <div class="gwmf-colgrid__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="gwmf-colgrid__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="gwmf-colgrid__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="gwmf-colgrid__filters">
        <button class="gwmf-filter__tag is-active" data-tag="all">All</button>
        {%- for block in section.blocks -%}
          <button
            class="gwmf-filter__tag"
            data-tag="{{ block.settings.tag | handleize }}"
            {{ block.shopify_attributes }}
          >{{ block.settings.label }}</button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="gwmf-colgrid__grid" id="gwmf-grid-{{ section.id }}">
      {%- if col != blank -%}
        {%- for product in col.products limit: limit -%}
          {%- assign tag_handles = '' -%}
          {%- for tag in product.tags -%}
            {%- assign tag_handles = tag_handles | append: tag | handleize | append: ' ' -%}
          {%- endfor -%}

          <div class="gwmf-prodcard" data-tags="{{ tag_handles | strip }}">
            <a href="{{ product.url }}" class="gwmf-prodcard__img-wrap">
              {%- if product.featured_image != blank -%}
                {%- assign img_alt = product.featured_image.alt | default: product.title | escape -%}
                {{
                  product.featured_image
                  | image_url: width: 600
                  | image_tag: alt: img_alt, loading: 'lazy', widths: '300, 400, 600'
                }}
              {%- else -%}
                <div class="gwmf-prodcard__img-placeholder">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/>
                  </svg>
                </div>
              {%- endif -%}
            </a>

            <a href="{{ product.url }}" class="gwmf-prodcard__title">{{ product.title }}</a>

            <div class="gwmf-prodcard__stars">★★★★★</div>

            <div class="gwmf-prodcard__price">
              <span class="gwmf-prodcard__price-sale">{{ product.price | money }}</span>
              {%- if product.compare_at_price > product.price -%}
                <span class="gwmf-prodcard__price-compare">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </div>

            {%- comment -%} Color swatches {%- endcomment -%}
            {%- assign color_index = nil -%}
            {%- for opt in product.options -%}
              {%- assign opt_lower = opt | downcase -%}
              {%- if opt_lower == 'color' or opt_lower == 'colour' -%}
                {%- assign color_index = forloop.index0 -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}

            {%- if color_index != nil -%}
              {%- assign shown = 0 -%}
              {%- assign seen_colors = '' -%}
              <div class="gwmf-prodcard__swatches">
                {%- for variant in product.variants -%}
                  {%- assign cval = variant.options[color_index] -%}
                  {%- assign ckey = cval | handleize -%}
                  {%- unless seen_colors contains ckey -%}
                    {%- assign seen_colors = seen_colors | append: ckey | append: ',' -%}
                    {%- if shown < 3 -%}
                      <span
                        class="gwmf-prodcard__swatch"
                        title="{{ cval | escape }}"
                        style="background-color: {{ cval | downcase | replace: ' ', '' }};"
                      ></span>
                      {%- assign shown = shown | plus: 1 -%}
                    {%- endif -%}
                  {%- endunless -%}
                {%- endfor -%}
                {%- assign total_colors = seen_colors | split: ',' | size -%}
                {%- if total_colors > 3 -%}
                  <span class="gwmf-prodcard__swatch-more">+{{ total_colors | minus: 3 }} more</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="gwmf-prodcard">
            <div class="gwmf-prodcard__img-wrap">
              <div class="gwmf-prodcard__img-placeholder">
                {{ 'product-' | append: i | placeholder_svg_tag }}
              </div>
            </div>
            <span class="gwmf-prodcard__title">Sample Product {{ i }}</span>
            <div class="gwmf-prodcard__stars">★★★★★</div>
            <div class="gwmf-prodcard__price">
              <span class="gwmf-prodcard__price-sale">$19.99</span>
              <span class="gwmf-prodcard__price-compare">$21.99</span>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.btn_label != blank -%}
      <div class="gwmf-colgrid__cta">
        <a href="{{ section.settings.btn_link | default: col.url }}" class="gwmf-colgrid__btn">
          {{ section.settings.btn_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</div>

<script>
  (function () {
    var sec = document.querySelector('#shopify-section-{{ section.id }} .gwmf-colgrid');
    if (!sec) return;

    /* Intersection observer for entrance animation */
    var io = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) { sec.classList.add('is-visible'); io.disconnect(); }
    }, { threshold: 0.08 });
    io.observe(sec);

    /* Tag filter */
    var btns = sec.querySelectorAll('.gwmf-filter__tag');
    var cards = sec.querySelectorAll('.gwmf-prodcard');

    btns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        btns.forEach(function (b) { b.classList.remove('is-active'); });
        this.classList.add('is-active');
        var tag = this.dataset.tag;
        cards.forEach(function (card) {
          if (tag === 'all' || card.dataset.tags.split(' ').indexOf(tag) > -1) {
            card.classList.remove('is-hidden');
          } else {
            card.classList.add('is-hidden');
          }
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Collection Grid",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a5fbe"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#7a8fa8"
    },
    {
      "type": "color",
      "id": "pill_border_color",
      "label": "Tag pill border color",
      "default": "#d0dce8"
    },
    {
      "type": "color",
      "id": "pill_text_color",
      "label": "Tag pill text color",
      "default": "#4a6080"
    },
    {
      "type": "color",
      "id": "pill_active_color",
      "label": "Tag pill active/hover color",
      "default": "#1a3a6e"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#1a5fbe"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button background color",
      "default": "#1a3a6e"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Gift Wrap"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Premium Quality. Printed Fast. Made for Laughs."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 8
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "SEE ALL"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "tag_filter",
      "name": "Tag Filter",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label (displayed on pill)",
          "default": "Birthdays"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag handle (must match product tag exactly)",
          "default": "birthdays"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Grid",
      "blocks": [
        { "type": "tag_filter", "settings": { "label": "Baby Shower", "tag": "baby-shower" } },
        { "type": "tag_filter", "settings": { "label": "Birthdays", "tag": "birthdays" } },
        { "type": "tag_filter", "settings": { "label": "Characters", "tag": "characters" } },
        { "type": "tag_filter", "settings": { "label": "Christmas", "tag": "christmas" } },
        { "type": "tag_filter", "settings": { "label": "Everyday", "tag": "everyday" } },
        { "type": "tag_filter", "settings": { "label": "Hanukkah", "tag": "hanukkah" } },
        { "type": "tag_filter", "settings": { "label": "Love", "tag": "love" } },
        { "type": "tag_filter", "settings": { "label": "Moms and Dads", "tag": "moms-and-dads" } },
        { "type": "tag_filter", "settings": { "label": "Pet Lovers", "tag": "pet-lovers" } }
      ]
    }
  ]
}
{% endschema %}
