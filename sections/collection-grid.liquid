{%- style -%}
  #shopify-section-{{ section.id }} {
    /* Colors */
    --grid-bg:           {{ section.settings.bg_color }};
    --grid-heading:      {{ section.settings.heading_color }};
    --grid-subtitle:     {{ section.settings.subtitle_color }};
    --grid-pill-border:  {{ section.settings.pill_border_color }};
    --grid-pill-text:    {{ section.settings.pill_text_color }};
    --grid-pill-active:  {{ section.settings.pill_active_color }};
    --grid-title-color:  {{ section.settings.title_color }};
    --grid-title-hover:  {{ section.settings.title_hover_color }};
    --grid-price:        {{ section.settings.price_color }};
    --grid-btn-bg:       {{ section.settings.btn_bg_color }};
    --grid-btn-text:     {{ section.settings.btn_text_color }};
    --grid-btn-bc:       {{ section.settings.btn_border_color }};
    /* Heading */
    --grid-head-font:       {{ section.settings.head_font }};
    --grid-head-size:       {{ section.settings.head_size }}px;
    --grid-head-weight:     {{ section.settings.head_weight }};
    --grid-head-transform:  {{ section.settings.head_transform }};
    --grid-head-ls:         {{ section.settings.head_ls | times: 0.1 }}px;
    --grid-head-lh:         {{ section.settings.head_lh | divided_by: 10.0 }};
    --grid-head-style:      {{ section.settings.head_style }};
    --grid-head-decoration: {{ section.settings.head_decoration }};
    /* Subtitle */
    --grid-sub-font:       {{ section.settings.sub_font }};
    --grid-sub-size:       {{ section.settings.sub_size }}px;
    --grid-sub-weight:     {{ section.settings.sub_weight }};
    --grid-sub-transform:  {{ section.settings.sub_transform }};
    --grid-sub-ls:         {{ section.settings.sub_ls | times: 0.1 }}px;
    --grid-sub-lh:         {{ section.settings.sub_lh | divided_by: 10.0 }};
    --grid-sub-style:      {{ section.settings.sub_style }};
    --grid-sub-decoration: {{ section.settings.sub_decoration }};
    /* Filter Pills */
    --grid-pill-font:      {{ section.settings.pill_font }};
    --grid-pill-size:      {{ section.settings.pill_size }}px;
    --grid-pill-weight:    {{ section.settings.pill_weight }};
    --grid-pill-transform: {{ section.settings.pill_transform }};
    --grid-pill-ls:        {{ section.settings.pill_ls | times: 0.1 }}px;
    --grid-pill-pv:        {{ section.settings.pill_pv }}px;
    --grid-pill-ph:        {{ section.settings.pill_ph }}px;
    --grid-pill-radius:    {{ section.settings.pill_radius }}px;
    /* Product Title */
    --grid-title-font:       {{ section.settings.title_font }};
    --grid-title-size:       {{ section.settings.title_size }}px;
    --grid-title-weight:     {{ section.settings.title_weight }};
    --grid-title-transform:  {{ section.settings.title_transform }};
    --grid-title-ls:         {{ section.settings.title_ls | times: 0.1 }}px;
    --grid-title-lh:         {{ section.settings.title_lh | divided_by: 10.0 }};
    --grid-title-style:      {{ section.settings.title_style }};
    --grid-title-decoration: {{ section.settings.title_decoration }};
    /* Price */
    --grid-price-size:   {{ section.settings.price_size }}px;
    --grid-price-weight: {{ section.settings.price_weight }};
    /* Button */
    --grid-btn-font:       {{ section.settings.btn_font }};
    --grid-btn-size:       {{ section.settings.btn_size }}px;
    --grid-btn-weight:     {{ section.settings.btn_weight }};
    --grid-btn-transform:  {{ section.settings.btn_transform }};
    --grid-btn-ls:         {{ section.settings.btn_ls | times: 0.1 }}px;
    --grid-btn-lh:         {{ section.settings.btn_lh | divided_by: 10.0 }};
    --grid-btn-style:      {{ section.settings.btn_style }};
    --grid-btn-decoration: {{ section.settings.btn_decoration }};
    --grid-btn-pv:         {{ section.settings.btn_pv }}px;
    --grid-btn-ph:         {{ section.settings.btn_ph }}px;
    --grid-btn-radius:     {{ section.settings.btn_radius }}px;
    --grid-btn-bw:         {{ section.settings.btn_bw }}px;
    --grid-btn-minw:       {{ section.settings.btn_minw }}px;
    /* Layout */
    --grid-pt: {{ section.settings.section_pt }}px;
    --grid-pb: {{ section.settings.section_pb }}px;
    /* Alignment & Container */
    --grid-align: {{ section.settings.content_align }};
    --grid-maxw:  {{ section.settings.content_max_width }}px;
    --grid-pl:    {{ section.settings.section_pl }}px;
    --grid-pr:    {{ section.settings.section_pr }}px;
    --grid-minh:  {{ section.settings.section_minh }}px;
    background-color: var(--grid-bg);
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --grid-head-size:  {{ section.settings.head_size_mobile }}px;
      --grid-sub-size:   {{ section.settings.sub_size_mobile }}px;
      --grid-pill-size:  {{ section.settings.pill_size_mobile }}px;
      --grid-title-size: {{ section.settings.title_size_mobile }}px;
      --grid-price-size: {{ section.settings.price_size_mobile }}px;
      --grid-btn-size:   {{ section.settings.btn_size_mobile }}px;
      --grid-pt: {{ section.settings.section_pt_mobile }}px;
      --grid-pb: {{ section.settings.section_pb_mobile }}px;
      --grid-pl: {{ section.settings.section_pl_mobile }}px;
      --grid-pr: {{ section.settings.section_pr_mobile }}px;
    }
  }
{%- endstyle -%}

<style>
  .gwmf-colgrid { width: 100%; }

  .gwmf-colgrid__inner {
    max-width: var(--grid-maxw); margin: 0 auto;
    padding: var(--grid-pt) var(--grid-pr) var(--grid-pb) var(--grid-pl);
    min-height: var(--grid-minh);
    text-align: var(--grid-align);
  }

  .gwmf-colgrid__heading {
    font-family: var(--grid-head-font);
    font-size: var(--grid-head-size);
    font-weight: var(--grid-head-weight);
    text-transform: var(--grid-head-transform);
    letter-spacing: var(--grid-head-ls);
    line-height: var(--grid-head-lh);
    font-style: var(--grid-head-style);
    text-decoration: var(--grid-head-decoration);
    color: var(--grid-heading);
    margin: 0 0 10px;
  }

  .gwmf-colgrid__subtitle {
    font-family: var(--grid-sub-font);
    font-size: var(--grid-sub-size);
    font-weight: var(--grid-sub-weight);
    text-transform: var(--grid-sub-transform);
    letter-spacing: var(--grid-sub-ls);
    line-height: var(--grid-sub-lh);
    font-style: var(--grid-sub-style);
    text-decoration: var(--grid-sub-decoration);
    color: var(--grid-subtitle);
    margin: 0 0 36px;
  }

  /* ---- TAG FILTER BAR ---- */
  .gwmf-colgrid__filters {
    display: flex; flex-wrap: wrap; align-items: center;
    justify-content: center; gap: 8px; margin-bottom: 40px;
  }

  .gwmf-filter__tag {
    font-family: var(--grid-pill-font);
    font-size: var(--grid-pill-size);
    font-weight: var(--grid-pill-weight);
    letter-spacing: var(--grid-pill-ls);
    text-transform: var(--grid-pill-transform);
    padding: var(--grid-pill-pv) var(--grid-pill-ph);
    border-radius: var(--grid-pill-radius);
    border: 2px solid var(--grid-pill-border);
    background: transparent;
    color: var(--grid-pill-text);
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .gwmf-filter__tag:hover { border-color: var(--grid-pill-active); color: var(--grid-pill-active); }
  .gwmf-filter__tag.is-active { background: var(--grid-pill-active); border-color: var(--grid-pill-active); color: #fff; }

  /* ---- PRODUCT GRID ---- */
  .gwmf-colgrid__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; text-align: center; }

  .gwmf-prodcard { display: flex; flex-direction: column; gap: 12px; transition: opacity 0.3s ease, transform 0.3s ease; }
  .gwmf-prodcard.is-hidden { display: none; }

  .gwmf-prodcard__img-wrap { position: relative; width: 100%; aspect-ratio: 1/1; border-radius: 12px; overflow: hidden; background: #f4f4f4; }
  .gwmf-prodcard__img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
  .gwmf-prodcard:hover .gwmf-prodcard__img-wrap img { transform: scale(1.04); }

  .gwmf-prodcard__img-wrap::after {
    content: ''; position: absolute; bottom: 0; right: 0;
    width: 0; height: 0; border-style: solid;
    border-width: 0 0 48px 48px;
    border-color: transparent transparent #ffffff transparent;
    filter: drop-shadow(-2px -2px 3px rgba(0,0,0,0.12)); z-index: 2;
  }

  .gwmf-prodcard__img-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #eef2f7; color: #b0bec5; }

  .gwmf-prodcard__title {
    font-family: var(--grid-title-font);
    font-size: var(--grid-title-size);
    font-weight: var(--grid-title-weight);
    text-transform: var(--grid-title-transform);
    letter-spacing: var(--grid-title-ls);
    line-height: var(--grid-title-lh);
    font-style: var(--grid-title-style);
    text-decoration: var(--grid-title-decoration);
    color: var(--grid-title-color);
    margin: 0; display: block;
  }

  .gwmf-prodcard__title:hover { color: var(--grid-title-hover); }

  .gwmf-prodcard__price { display: flex; align-items: center; justify-content: center; gap: 6px; flex-wrap: wrap; }

  .gwmf-prodcard__price-sale {
    font-family: var(--grid-sub-font);
    font-size: var(--grid-price-size);
    font-weight: var(--grid-price-weight);
    color: var(--grid-price);
  }

  .gwmf-prodcard__price-compare {
    font-family: var(--grid-sub-font);
    font-size: var(--grid-price-size);
    font-weight: 500;
    color: #9eaab8;
    text-decoration: line-through;
  }

  .gwmf-prodcard__badge {
    display: inline-block; font-family: 'Outfit', sans-serif;
    font-size: 10px; font-weight: 700; letter-spacing: 0.5px;
    text-transform: uppercase; padding: 2px 7px; border-radius: 4px; line-height: 1.6;
  }
  .gwmf-prodcard__badge--sale { background: #e8430a; color: #fff; }
  .gwmf-prodcard__badge--soldout { background: #9eaab8; color: #fff; }
  .gwmf-prodcard__price-from { font-family: var(--grid-sub-font); font-size: 24px; font-weight: 500; color: #0065AC; }

  .gwmf-prodcard__swatches { display: flex; align-items: center; justify-content: center; gap: 6px; flex-wrap: wrap; }
  .gwmf-prodcard__swatch { width: 22px; height: 22px; border-radius: 50%; border: 2px solid #fff; box-shadow: 0 0 0 1.5px #d0dce8; display: inline-block; flex-shrink: 0; }
  .gwmf-prodcard__swatch-thumb { display: inline-block; width: 36px; height: 36px; border-radius: 50px; overflow: hidden; border: 2px solid #fff; box-shadow: 0 0 0 1.5px #d0dce8; flex-shrink: 0; transition: box-shadow 0.18s; }
  .gwmf-prodcard__swatch-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .gwmf-prodcard__swatch-thumb:hover { box-shadow: 0 0 0 2px #1a5fbe; }
  .gwmf-prodcard__swatch-more { font-family: 'Outfit', sans-serif; font-size: 12px; font-weight: 600; color: #6a7f96; }

  /* SEE ALL button */
  .gwmf-colgrid__cta { margin-top: 48px; }

  .gwmf-colgrid__btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: var(--grid-btn-pv) var(--grid-btn-ph);
    background: var(--grid-btn-bg);
    color: var(--grid-btn-text);
    font-family: var(--grid-btn-font);
    font-size: var(--grid-btn-size);
    font-weight: var(--grid-btn-weight);
    text-transform: var(--grid-btn-transform);
    letter-spacing: var(--grid-btn-ls);
    line-height: var(--grid-btn-lh);
    font-style: var(--grid-btn-style);
    text-decoration: var(--grid-btn-decoration);
    border: var(--grid-btn-bw) solid var(--grid-btn-bc);
    border-radius: var(--grid-btn-radius);
    min-width: var(--grid-btn-minw);
    transition: filter 0.2s, transform 0.15s;
  }

  .gwmf-colgrid__btn:hover { filter: brightness(0.85); transform: translateY(-2px); }

  /* ---- ANIMATIONS ---- */
  .gwmf-colgrid__heading, .gwmf-colgrid__subtitle, .gwmf-colgrid__filters, .gwmf-prodcard, .gwmf-colgrid__cta {
    opacity: 0; transform: translateY(28px); transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .gwmf-colgrid.is-visible .gwmf-colgrid__heading  { opacity: 1; transform: translateY(0); transition-delay: 0s; }
  .gwmf-colgrid.is-visible .gwmf-colgrid__subtitle { opacity: 1; transform: translateY(0); transition-delay: 0.08s; }
  .gwmf-colgrid.is-visible .gwmf-colgrid__filters  { opacity: 1; transform: translateY(0); transition-delay: 0.16s; }
  .gwmf-colgrid.is-visible .gwmf-prodcard:nth-child(1) { opacity: 1; transform: translateY(0); transition-delay: 0.24s; }
  .gwmf-colgrid.is-visible .gwmf-prodcard:nth-child(2) { opacity: 1; transform: translateY(0); transition-delay: 0.34s; }
  .gwmf-colgrid.is-visible .gwmf-prodcard:nth-child(3) { opacity: 1; transform: translateY(0); transition-delay: 0.44s; }
  .gwmf-colgrid.is-visible .gwmf-prodcard:nth-child(4) { opacity: 1; transform: translateY(0); transition-delay: 0.54s; }
  .gwmf-colgrid.is-visible .gwmf-prodcard:nth-child(n+5) { opacity: 1; transform: translateY(0); transition-delay: 0.6s; }
  .gwmf-colgrid.is-visible .gwmf-colgrid__cta { opacity: 1; transform: translateY(0); transition-delay: 0.65s; }

  /* ---- RESPONSIVE ---- */
  @media screen and (max-width: 1199px) {
    .gwmf-colgrid__inner { padding: calc(var(--grid-pt)*0.81) calc(var(--grid-pr)*0.75) calc(var(--grid-pb)*0.83) calc(var(--grid-pl)*0.75); }
    .gwmf-colgrid__grid { grid-template-columns: repeat(3, 1fr); gap: 22px; }
  }
  @media screen and (max-width: 989px) {
    .gwmf-colgrid__inner { padding: calc(var(--grid-pt)*0.69) calc(var(--grid-pr)*0.75) calc(var(--grid-pb)*0.72) calc(var(--grid-pl)*0.75); }
    .gwmf-colgrid__grid { grid-template-columns: repeat(2, 1fr); gap: 18px; }
  }
  @media screen and (max-width: 749px) {
    .gwmf-colgrid__inner { padding: var(--grid-pt) var(--grid-pr) var(--grid-pb) var(--grid-pl); }
    .gwmf-colgrid__filters { flex-wrap: nowrap; overflow-x: auto; scrollbar-width: none; justify-content: flex-start; padding-bottom: 4px; margin: 0 -16px 40px; padding-left: 16px; padding-right: 16px; }
    .gwmf-colgrid__filters::-webkit-scrollbar { display: none; }
    .gwmf-filter__tag { flex-shrink: 0; }
    .gwmf-colgrid__grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
  }
  @media screen and (max-width: 480px) {
    .gwmf-colgrid__grid { grid-template-columns: 1fr 1fr; gap: 12px; }
  }
</style>

{%- liquid
  assign col = collections[section.settings.collection]
  assign limit = section.settings.products_to_show | default: 8
-%}

<div class="gwmf-colgrid" id="shopify-section-{{ section.id }}">
  <div class="gwmf-colgrid__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="gwmf-colgrid__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="gwmf-colgrid__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="gwmf-colgrid__filters">
        <button class="gwmf-filter__tag is-active" data-tag="all">All</button>
        {%- for block in section.blocks -%}
          <button class="gwmf-filter__tag" data-tag="{{ block.settings.tag | handleize }}" {{ block.shopify_attributes }}>{{ block.settings.label }}</button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="gwmf-colgrid__grid" id="gwmf-grid-{{ section.id }}">
      {%- if col != blank -%}
        {%- for product in col.products limit: limit -%}
          {%- assign tag_handles = '' -%}
          {%- for tag in product.tags -%}
            {%- assign tag_handles = tag_handles | append: tag | handleize | append: ' ' -%}
          {%- endfor -%}

          <div class="gwmf-prodcard" data-tags="{{ tag_handles | strip }}">
            <a href="{{ product.url }}" class="gwmf-prodcard__img-wrap">
              {%- if product.featured_image != blank -%}
                {%- assign img_alt = product.featured_image.alt | default: product.title | escape -%}
                {{ product.featured_image | image_url: width: 600 | image_tag: alt: img_alt, loading: 'lazy', widths: '300, 400, 600' }}
              {%- else -%}
                <div class="gwmf-prodcard__img-placeholder">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                </div>
              {%- endif -%}
            </a>

            <a href="{{ product.url }}" class="gwmf-prodcard__title">{{ product.title }}</a>

            <div class="gwmf-prodcard__price">
              {%- if product.available == false -%}
                <span class="gwmf-prodcard__badge gwmf-prodcard__badge--soldout">Sold Out</span>
              {%- endif -%}
              <span class="gwmf-prodcard__price-from">FROM</span>
              <span class="gwmf-prodcard__price-sale">{{ product.price_min | money }}</span>
            </div>

            {%- comment -%} Variant thumbnails — show up to 3 unique variant images, fall back to color swatches {%- endcomment -%}
            {%- assign has_variant_imgs = false -%}
            {%- for variant in product.variants limit: 8 -%}
              {%- if variant.featured_image != blank -%}
                {%- assign has_variant_imgs = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}

            {%- if has_variant_imgs -%}
              {%- assign shown_v = 0 -%}
              {%- assign seen_img_ids = '' -%}
              <div class="gwmf-prodcard__swatches">
                {%- for variant in product.variants -%}
                  {%- if shown_v >= 3 -%}{%- break -%}{%- endif -%}
                  {%- if variant.featured_image != blank -%}
                    {%- assign img_id = variant.featured_image.id | append: '' -%}
                    {%- unless seen_img_ids contains img_id -%}
                      {%- assign seen_img_ids = seen_img_ids | append: img_id | append: ',' -%}
                      <a href="{{ product.url }}?variant={{ variant.id }}" class="gwmf-prodcard__swatch-thumb" title="{{ variant.title | escape }}">
                        {{ variant.featured_image | image_url: width: 80 | image_tag: alt: variant.title, loading: 'lazy' }}
                      </a>
                      {%- assign shown_v = shown_v | plus: 1 -%}
                    {%- endunless -%}
                  {%- endif -%}
                {%- endfor -%}
                {%- if product.variants.size > 3 -%}
                  <span class="gwmf-prodcard__swatch-more">+{{ product.variants.size | minus: 3 }} more</span>
                {%- endif -%}
              </div>
            {%- else -%}
              {%- assign color_index = nil -%}
              {%- for opt in product.options -%}
                {%- assign opt_lower = opt | downcase -%}
                {%- if opt_lower == 'color' or opt_lower == 'colour' -%}
                  {%- assign color_index = forloop.index0 -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
              {%- if color_index != nil -%}
                {%- assign shown = 0 -%}
                {%- assign seen_colors = '' -%}
                <div class="gwmf-prodcard__swatches">
                  {%- for variant in product.variants -%}
                    {%- assign cval = variant.options[color_index] -%}
                    {%- assign ckey = cval | handleize -%}
                    {%- unless seen_colors contains ckey -%}
                      {%- assign seen_colors = seen_colors | append: ckey | append: ',' -%}
                      {%- if shown < 3 -%}
                        <span class="gwmf-prodcard__swatch" title="{{ cval | escape }}" style="background-color: {{ cval | downcase | replace: ' ', '' }};"></span>
                        {%- assign shown = shown | plus: 1 -%}
                      {%- endif -%}
                    {%- endunless -%}
                  {%- endfor -%}
                  {%- assign total_colors = seen_colors | split: ',' | size -%}
                  {%- if total_colors > 3 -%}
                    <span class="gwmf-prodcard__swatch-more">+{{ total_colors | minus: 3 }} more</span>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="gwmf-prodcard">
            <div class="gwmf-prodcard__img-wrap">
              <div class="gwmf-prodcard__img-placeholder">{{ 'product-' | append: i | placeholder_svg_tag }}</div>
            </div>
            <span class="gwmf-prodcard__title">Sample Product {{ i }}</span>
            <div class="gwmf-prodcard__price">
              <span class="gwmf-prodcard__price-from">From</span>
              <span class="gwmf-prodcard__price-sale">{{ 1999 | money }}</span>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.btn_label != blank -%}
      <div class="gwmf-colgrid__cta">
        <a href="{{ section.settings.btn_link | default: col.url }}" class="gwmf-colgrid__btn">{{ section.settings.btn_label }}</a>
      </div>
    {%- endif -%}

  </div>
</div>

<script>
  (function () {
    var sec = document.querySelector('#shopify-section-{{ section.id }} .gwmf-colgrid');
    if (!sec) return;
    var io = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) { sec.classList.add('is-visible'); io.disconnect(); }
    }, { threshold: 0.08 });
    io.observe(sec);
    var btns = sec.querySelectorAll('.gwmf-filter__tag');
    var cards = sec.querySelectorAll('.gwmf-prodcard');
    btns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        btns.forEach(function (b) { b.classList.remove('is-active'); });
        this.classList.add('is-active');
        var tag = this.dataset.tag;
        cards.forEach(function (card) {
          if (tag === 'all' || card.dataset.tags.split(' ').indexOf(tag) > -1) {
            card.classList.remove('is-hidden');
          } else {
            card.classList.add('is-hidden');
          }
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Collection Grid",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color",         "label": "Background",           "default": "#ffffff" },
