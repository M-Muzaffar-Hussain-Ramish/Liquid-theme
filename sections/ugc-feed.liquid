{%- style -%}
  #shopify-section-{{ section.id }} {
    width: 100% !important; max-width: 100% !important;
    /* Colors */
    --ugc-bg:             {{ section.settings.bg_color }};
    --ugc-eyebrow:        {{ section.settings.eyebrow_color }};
    --ugc-heading:        {{ section.settings.heading_color }};
    --ugc-heading-accent: {{ section.settings.heading_accent_color }};
    --ugc-subtext:        {{ section.settings.subtext_color }};
    --ugc-hashtag:        {{ section.settings.hashtag_color }};
    /* Eyebrow */
    --ugc-eye-font:      {{ section.settings.eye_font }};
    --ugc-eye-size:      {{ section.settings.eye_size }}px;
    --ugc-eye-weight:    {{ section.settings.eye_weight }};
    --ugc-eye-transform: {{ section.settings.eye_transform }};
    --ugc-eye-ls:        {{ section.settings.eye_ls | times: 0.1 }}px;
    --ugc-eye-lh:        {{ section.settings.eye_lh | divided_by: 10.0 }};
    --ugc-eye-style:      {{ section.settings.eye_style }};
    --ugc-eye-decoration: {{ section.settings.eye_decoration }};
    /* Heading */
    --ugc-head-font:       {{ section.settings.head_font }};
    --ugc-head-size:       {{ section.settings.head_size }}px;
    --ugc-head-weight:     {{ section.settings.head_weight }};
    --ugc-head-transform:  {{ section.settings.head_transform }};
    --ugc-head-ls:         {{ section.settings.head_ls | times: 0.1 }}px;
    --ugc-head-lh:         {{ section.settings.head_lh | divided_by: 10.0 }};
    --ugc-head-style:      {{ section.settings.head_style }};
    --ugc-head-decoration: {{ section.settings.head_decoration }};
    /* Subtext */
    --ugc-sub-font:       {{ section.settings.sub_font }};
    --ugc-sub-size:       {{ section.settings.sub_size }}px;
    --ugc-sub-weight:     {{ section.settings.sub_weight }};
    --ugc-sub-transform:  {{ section.settings.sub_transform }};
    --ugc-sub-ls:         {{ section.settings.sub_ls | times: 0.1 }}px;
    --ugc-sub-lh:         {{ section.settings.sub_lh | divided_by: 10.0 }};
    --ugc-sub-style:      {{ section.settings.sub_style }};
    --ugc-sub-decoration: {{ section.settings.sub_decoration }};
    /* Layout */
    --ugc-card-radius: {{ section.settings.card_radius }}px;
    --ugc-pt:          {{ section.settings.section_pt }}px;
    --ugc-pb:          {{ section.settings.section_pb }}px;
    /* Alignment & Container */
    --ugc-align: {{ section.settings.content_align }};
    --ugc-maxw:  {{ section.settings.content_max_width }}px;
    --ugc-pl:    {{ section.settings.section_pl }}px;
    --ugc-pr:    {{ section.settings.section_pr }}px;
    --ugc-minh:  {{ section.settings.section_minh }}px;
    background-color: var(--ugc-bg);
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --ugc-eye-size:  {{ section.settings.eye_size_mobile }}px;
      --ugc-head-size: {{ section.settings.head_size_mobile }}px;
      --ugc-sub-size:  {{ section.settings.sub_size_mobile }}px;
      --ugc-pt: {{ section.settings.section_pt_mobile }}px;
      --ugc-pb: {{ section.settings.section_pb_mobile }}px;
      --ugc-pl: {{ section.settings.section_pl_mobile }}px;
      --ugc-pr: {{ section.settings.section_pr_mobile }}px;
    }
  }
{%- endstyle -%}

<style>
  .gwmf-ugc { width: 100%; background-color: var(--ugc-bg); padding: var(--ugc-pt) 0 var(--ugc-pb); overflow: hidden; }

  .gwmf-ugc__header { max-width: var(--ugc-maxw); margin-left: auto; margin-right: auto; text-align: var(--ugc-align); padding: 0 var(--ugc-pr) 0 var(--ugc-pl); margin-bottom: 48px; }
  .gwmf-ugc { min-height: var(--ugc-minh); }

  .gwmf-ugc__eyebrow {
    font-family: var(--ugc-eye-font);
    font-size: var(--ugc-eye-size);
    font-weight: var(--ugc-eye-weight);
    text-transform: var(--ugc-eye-transform);
    letter-spacing: var(--ugc-eye-ls);
    line-height: var(--ugc-eye-lh);
    font-style: var(--ugc-eye-style);
    text-decoration: var(--ugc-eye-decoration);
    color: var(--ugc-eyebrow); margin: 0 0 12px;
  }

  .gwmf-ugc__heading {
    font-family: var(--ugc-head-font);
    font-size: var(--ugc-head-size);
    font-weight: var(--ugc-head-weight);
    text-transform: var(--ugc-head-transform);
    letter-spacing: var(--ugc-head-ls);
    line-height: var(--ugc-head-lh);
    font-style: var(--ugc-head-style);
    text-decoration: var(--ugc-head-decoration);
    color: var(--ugc-heading); margin: 0 0 16px;
  }

  .gwmf-ugc__heading em { font-style: normal; color: var(--ugc-heading-accent); }

  .gwmf-ugc__subtext {
    font-family: var(--ugc-sub-font);
    font-size: var(--ugc-sub-size);
    font-weight: var(--ugc-sub-weight);
    text-transform: var(--ugc-sub-transform);
    letter-spacing: var(--ugc-sub-ls);
    line-height: var(--ugc-sub-lh);
    font-style: var(--ugc-sub-style);
    text-decoration: var(--ugc-sub-decoration);
    color: var(--ugc-subtext); margin: 0;
  }

  .gwmf-ugc__subtext strong { color: var(--ugc-hashtag); font-weight: 700; }

  .gwmf-ugc__track-wrap { position: relative; width: 100%; overflow: hidden; }

  .gwmf-ugc__track {
    display: flex; gap: 20px; width: max-content;
    animation: gwmf-ugc-scroll {{ section.settings.scroll_speed }}s linear infinite;
  }

  .gwmf-ugc__track:hover { animation-play-state: paused; }

  @keyframes gwmf-ugc-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .gwmf-ugc__card {
    position: relative; flex-shrink: 0;
    width: {{ section.settings.card_size }}px;
    height: {{ section.settings.card_size }}px;
    border-radius: var(--ugc-card-radius);
    overflow: hidden; display: block; text-decoration: none;
  }

  .gwmf-ugc__card img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
  .gwmf-ugc__card:hover img { transform: scale(1.06); }

  .gwmf-ugc__badge { position: absolute; bottom: 12px; left: 12px; width: 32px; height: 32px; background: rgba(255,255,255,0.88); border-radius: 8px; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
  .gwmf-ugc__badge svg { width: 18px; height: 18px; }
  .gwmf-ugc__card-placeholder { width: 100%; height: 100%; background: #e8edf2; display: flex; align-items: center; justify-content: center; color: rgba(0,0,0,0.2); }

  .gwmf-ugc__eyebrow, .gwmf-ugc__heading, .gwmf-ugc__subtext { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .gwmf-ugc__track-wrap { opacity: 0; transform: translateY(20px); transition: opacity 0.7s ease 0.25s, transform 0.7s ease 0.25s; }
  .gwmf-ugc.is-visible .gwmf-ugc__eyebrow { opacity: 1; transform: translateY(0); transition-delay: 0s; }
  .gwmf-ugc.is-visible .gwmf-ugc__heading { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
  .gwmf-ugc.is-visible .gwmf-ugc__subtext { opacity: 1; transform: translateY(0); transition-delay: 0.18s; }
  .gwmf-ugc.is-visible .gwmf-ugc__track-wrap { opacity: 1; transform: translateY(0); }

  @media screen and (max-width: 989px) {
    .gwmf-ugc { padding: calc(var(--ugc-pt)*0.72) 0 calc(var(--ugc-pb)*0.75); }
    .gwmf-ugc__header { margin-bottom: 36px; }
  }
  @media screen and (max-width: 749px) {
    .gwmf-ugc { padding: var(--ugc-pt) 0 var(--ugc-pb); }
    .gwmf-ugc__card { width: 240px; height: 240px; }
  }
  @media screen and (max-width: 480px) {
    .gwmf-ugc { padding: var(--ugc-pt) 0 var(--ugc-pb); }
    .gwmf-ugc__card { width: 200px; height: 200px; }
    .gwmf-ugc__track { gap: 14px; }
  }
</style>

<section class="gwmf-ugc" id="shopify-section-{{ section.id }}">
  <div class="gwmf-ugc__header">
    {%- if section.settings.eyebrow != blank -%}<p class="gwmf-ugc__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="gwmf-ugc__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.subtext != blank -%}<p class="gwmf-ugc__subtext">{{ section.settings.subtext }}</p>{%- endif -%}
  </div>
  {%- if section.blocks.size > 0 -%}
    <div class="gwmf-ugc__track-wrap">
      <div class="gwmf-ugc__track">
        {%- for block in section.blocks -%}
          {%- assign card_href = block.settings.link | default: section.settings.instagram_url -%}
          <a class="gwmf-ugc__card" href="{{ card_href }}" target="_blank" rel="noopener noreferrer" aria-label="View on Instagram" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: alt: 'Customer photo', loading: 'lazy', widths: '300, 400, 600' }}
            {%- else -%}
              <div class="gwmf-ugc__card-placeholder"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg></div>
            {%- endif -%}
            <div class="gwmf-ugc__badge"><svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="ig-grad-{{ block.id }}" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" stop-color="#fd5949"/><stop offset="50%" stop-color="#d6249f"/><stop offset="100%" stop-color="#285AEB"/></linearGradient></defs><rect x="2" y="2" width="20" height="20" rx="5.5" stroke="url(#ig-grad-{{ block.id }})" stroke-width="1.8" fill="none"/><circle cx="12" cy="12" r="4.5" stroke="url(#ig-grad-{{ block.id }})" stroke-width="1.8" fill="none"/><circle cx="17.5" cy="6.5" r="1" fill="#d6249f"/></svg></div>
          </a>
        {%- endfor -%}
        {%- for block in section.blocks -%}
          {%- assign card_href = block.settings.link | default: section.settings.instagram_url -%}
          <a class="gwmf-ugc__card" href="{{ card_href }}" target="_blank" rel="noopener noreferrer" aria-label="View on Instagram" aria-hidden="true" tabindex="-1">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: alt: 'Customer photo', loading: 'lazy', widths: '300, 400, 600' }}
            {%- else -%}
              <div class="gwmf-ugc__card-placeholder"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg></div>
            {%- endif -%}
            <div class="gwmf-ugc__badge"><svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="ig-grad2-{{ block.id }}" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" stop-color="#fd5949"/><stop offset="50%" stop-color="#d6249f"/><stop offset="100%" stop-color="#285AEB"/></linearGradient></defs><rect x="2" y="2" width="20" height="20" rx="5.5" stroke="url(#ig-grad2-{{ block.id }})" stroke-width="1.8" fill="none"/><circle cx="12" cy="12" r="4.5" stroke="url(#ig-grad2-{{ block.id }})" stroke-width="1.8" fill="none"/><circle cx="17.5" cy="6.5" r="1" fill="#d6249f"/></svg></div>
          </a>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

<script>
  (function () {
    var sec = document.querySelector('#shopify-section-{{ section.id }} .gwmf-ugc');
    if (!sec) return;
    var io = new IntersectionObserver(function (entries) { if (entries[0].isIntersecting) { sec.classList.add('is-visible'); io.disconnect(); } }, { threshold: 0.1 });
    io.observe(sec);
  })();
</script>

{% schema %}
{
  "name": "UGC / Instagram Feed",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "#1a5fbe" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#1a3a6e" },
    { "type": "color", "id": "heading_accent_color", "label": "Heading accent color", "default": "#e8430a" },
    { "type": "color", "id": "subtext_color", "label": "Subtext color", "default": "#4a5568" },
    { "type": "color", "id": "hashtag_color", "label": "Hashtag color", "default": "#e8430a" },

    { "type": "header", "content": "Typography — Eyebrow" },
    { "type": "select", "id": "eye_font", "label": "Font family", "options": [{ "value": "Outfit, sans-serif", "label": "Outfit (Body)" }, { "value": "Dimbo, Outfit, sans-serif", "label": "Dimbo (Display)" }], "default": "Outfit, sans-serif" },
    { "type": "range", "id": "eye_size", "label": "Size (px)", "min": 10, "max": 100, "step": 1, "default": 14 },
    { "type": "select", "id": "eye_weight", "label": "Weight", "options": [{ "value": "400", "label": "400" }, { "value": "500", "label": "500" }, { "value": "600", "label": "600" }, { "value": "700", "label": "700" }, { "value": "800", "label": "800" }], "default": "700" },
    { "type": "select", "id": "eye_transform", "label": "Text transform", "options": [{ "value": "none", "label": "None" }, { "value": "uppercase", "label": "UPPERCASE" }, { "value": "lowercase", "label": "lowercase" }, { "value": "capitalize", "label": "Capitalize" }], "default": "none" },
    { "type": "range", "id": "eye_ls", "label": "Letter spacing (×0.1px)", "min": -20, "max": 200, "step": 5, "default": 0 },
    { "type": "range", "id": "eye_lh", "label": "Line height (÷10)", "min": 8, "max": 50, "step": 1, "default": 14 },
    { "type": "select", "id": "eye_style", "label": "Font style", "options": [{ "value": "normal", "label": "Normal" }, { "value": "italic", "label": "Italic" }], "default": "normal" },
    { "type": "select", "id": "eye_decoration", "label": "Text decoration", "options": [{ "value": "none", "label": "None" }, { "value": "underline", "label": "Underline" }, { "value": "line-through", "label": "Line-through" }], "default": "none" },

    { "type": "header", "content": "Typography — Heading" },
    { "type": "select", "id": "head_font", "label": "Font family", "options": [{ "value": "Dimbo, Outfit, sans-serif", "label": "Dimbo (Display)" }, { "value": "Outfit, sans-serif", "label": "Outfit (Body)" }], "default": "Dimbo, Outfit, sans-serif" },
    { "type": "range", "id": "head_size", "label": "Size — desktop (px)", "min": 24, "max": 224, "step": 2, "default": 56 },
    { "type": "select", "id": "head_weight", "label": "Weight", "options": [{ "value": "400", "label": "400" }, { "value": "500", "label": "500" }, { "value": "600", "label": "600" }, { "value": "700", "label": "700" }, { "value": "800", "label": "800" }, { "value": "900", "label": "900" }], "default": "800" },
    { "type": "select", "id": "head_transform", "label": "Text transform", "options": [{ "value": "none", "label": "None" }, { "value": "uppercase", "label": "UPPERCASE" }, { "value": "lowercase", "label": "lowercase" }, { "value": "capitalize", "label": "Capitalize" }], "default": "none" },
    { "type": "range", "id": "head_ls", "label": "Letter spacing (×0.1px)", "min": -20, "max": 200, "step": 5, "default": 0 },
    { "type": "range", "id": "head_lh", "label": "Line height (÷10)", "min": 6, "max": 50, "step": 1, "default": 11 },
    { "type": "select", "id": "head_style", "label": "Font style", "options": [{ "value": "normal", "label": "Normal" }, { "value": "italic", "label": "Italic" }], "default": "normal" },
    { "type": "select", "id": "head_decoration", "label": "Text decoration", "options": [{ "value": "none", "label": "None" }, { "value": "underline", "label": "Underline" }, { "value": "line-through", "label": "Line-through" }], "default": "none" },

    { "type": "header", "content": "Typography — Subtext" },
    { "type": "select", "id": "sub_font", "label": "Font family", "options": [{ "value": "Outfit, sans-serif", "label": "Outfit (Body)" }, { "value": "Dimbo, Outfit, sans-serif", "label": "Dimbo (Display)" }], "default": "Outfit, sans-serif" },
    { "type": "range", "id": "sub_size", "label": "Size (px)", "min": 12, "max": 112, "step": 1, "default": 16 },
    { "type": "select", "id": "sub_weight", "label": "Weight", "options": [{ "value": "400", "label": "400" }, { "value": "500", "label": "500" }, { "value": "600", "label": "600" }, { "value": "700", "label": "700" }], "default": "500" },
    { "type": "select", "id": "sub_transform", "label": "Text transform", "options": [{ "value": "none", "label": "None" }, { "value": "uppercase", "label": "UPPERCASE" }, { "value": "lowercase", "label": "lowercase" }, { "value": "capitalize", "label": "Capitalize" }], "default": "none" },
    { "type": "range", "id": "sub_ls", "label": "Letter spacing (×0.1px)", "min": -20, "max": 200, "step": 5, "default": 0 },
    { "type": "range", "id": "sub_lh", "label": "Line height (÷10)", "min": 8, "max": 50, "step": 1, "default": 15 },
    { "type": "select", "id": "sub_style", "label": "Font style", "options": [{ "value": "normal", "label": "Normal" }, { "value": "italic", "label": "Italic" }], "default": "normal" },
    { "type": "select", "id": "sub_decoration", "label": "Text decoration", "options": [{ "value": "none", "label": "None" }, { "value": "underline", "label": "Underline" }, { "value": "line-through", "label": "Line-through" }], "default": "none" },

    { "type": "header", "content": "Spacing & Layout" },
    { "type": "range", "id": "section_pt", "label": "Padding top (px)", "min": 0, "max": 400, "step": 4, "default": 72 },
    { "type": "range", "id": "section_pb", "label": "Padding bottom (px)", "min": 0, "max": 400, "step": 4, "default": 80 },

    { "type": "header", "content": "Mobile Sizes" },
    { "type": "range", "id": "eye_size_mobile",   "label": "Eyebrow size — mobile (px)", "min": 10, "max": 100, "step": 1, "default": 13 },
    { "type": "range", "id": "head_size_mobile",  "label": "Heading size — mobile (px)", "min": 24, "max": 224, "step": 2, "default": 40 },
    { "type": "range", "id": "sub_size_mobile",   "label": "Subtext size — mobile (px)", "min": 12, "max": 112, "step": 1, "default": 14 },
    { "type": "range", "id": "section_pt_mobile", "label": "Padding top — mobile (px)",  "min": 0,  "max": 400, "step": 4, "default": 40 },
    { "type": "range", "id": "section_pb_mobile", "label": "Padding bottom — mobile (px)","min": 0,  "max": 400, "step": 4, "default": 48 },
    { "type": "range", "id": "section_pl_mobile", "label": "Padding left — mobile (px)",  "min": 0,  "max": 200, "step": 4, "default": 20 },
    { "type": "range", "id": "section_pr_mobile", "label": "Padding right — mobile (px)", "min": 0,  "max": 200, "step": 4, "default": 20 },

    { "type": "header", "content": "Alignment & Container" },
    { "type": "select", "id": "content_align", "label": "Text alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "center" },
    { "type": "range", "id": "content_max_width", "label": "Container max width (px)", "min": 400, "max": 1600, "step": 20, "default": 1400 },
    { "type": "range", "id": "section_pl", "label": "Padding left (px)", "min": 0, "max": 200, "step": 4, "default": 20 },
    { "type": "range", "id": "section_pr", "label": "Padding right (px)", "min": 0, "max": 200, "step": 4, "default": 20 },
    { "type": "range", "id": "section_minh", "label": "Min height (px)", "min": 0, "max": 800, "step": 8, "default": 0 },

    { "type": "header", "content": "Photo Cards" },
    { "type": "range", "id": "card_size", "label": "Card size (px)", "min": 160, "max": 1160, "step": 10, "default": 290 },
    { "type": "range", "id": "card_radius", "label": "Card border radius (px)", "min": 0, "max": 200, "step": 2, "default": 20 },
    { "type": "range", "id": "scroll_speed", "label": "Scroll speed (seconds per loop)", "min": 10, "max": 300, "step": 5, "default": 30 },

    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Join the Wrap Party Online!" },
    { "type": "text", "id": "heading", "label": "Heading (wrap accent words in <em></em>)", "default": "Find Us. <em>Tag Us.</em> Laugh With Us." },
    { "type": "text", "id": "subtext", "label": "Subtext (wrap hashtag in <strong></strong>)", "default": "Tag us with <strong>#GiftWrapMyFace</strong> and you might just get featured!" },
    { "type": "url", "id": "instagram_url", "label": "Default Instagram link" }
  ],
  "blocks": [
    { "type": "photo", "name": "Photo", "settings": [{ "type": "image_picker", "id": "image", "label": "Photo" }, { "type": "url", "id": "link", "label": "Link (overrides section URL)" }] }
  ],
  "presets": [{ "name": "UGC / Instagram Feed", "blocks": [{ "type": "photo" }, { "type": "photo" }, { "type": "photo" }, { "type": "photo" }, { "type": "photo" }, { "type": "photo" }] }]
}
{% endschema %}
