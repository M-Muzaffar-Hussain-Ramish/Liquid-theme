{%- style -%}
  #shopify-section-{{ section.id }} {
    /* Colors */
    --cats-bg:       {{ section.settings.bg_color }};
    --cats-eyebrow:  {{ section.settings.eyebrow_color }};
    --cats-heading:  {{ section.settings.heading_color }};
    --cats-subtitle: {{ section.settings.subtitle_color }};
    --cats-label:    {{ section.settings.label_color }};
    --cats-cardsub:  {{ section.settings.card_subtitle_color }};
    --cats-btn-bg:   {{ section.settings.btn_bg_color }};
    --cats-btn-text: {{ section.settings.btn_text_color }};
    --cats-btn-bc:   {{ section.settings.btn_border_color }};
    /* Eyebrow */
    --cats-eye-font:      {{ section.settings.eye_font }};
    --cats-eye-size:      {{ section.settings.eye_size }}px;
    --cats-eye-weight:    {{ section.settings.eye_weight }};
    --cats-eye-transform: {{ section.settings.eye_transform }};
    --cats-eye-ls:        {{ section.settings.eye_ls | times: 0.1 }}px;
    --cats-eye-lh:        {{ section.settings.eye_lh | divided_by: 10.0 }};
    --cats-eye-style:      {{ section.settings.eye_style }};
    --cats-eye-decoration: {{ section.settings.eye_decoration }};
    /* Section Heading */
    --cats-head-font:       {{ section.settings.head_font }};
    --cats-head-size:       {{ section.settings.head_size }}px;
    --cats-head-weight:     {{ section.settings.head_weight }};
    --cats-head-transform:  {{ section.settings.head_transform }};
    --cats-head-ls:         {{ section.settings.head_ls | times: 0.1 }}px;
    --cats-head-lh:         {{ section.settings.head_lh | divided_by: 10.0 }};
    --cats-head-style:      {{ section.settings.head_style }};
    --cats-head-decoration: {{ section.settings.head_decoration }};
    /* Subtitle */
    --cats-sub-font:       {{ section.settings.sub_font }};
    --cats-sub-size:       {{ section.settings.sub_size }}px;
    --cats-sub-weight:     {{ section.settings.sub_weight }};
    --cats-sub-transform:  {{ section.settings.sub_transform }};
    --cats-sub-ls:         {{ section.settings.sub_ls | times: 0.1 }}px;
    --cats-sub-lh:         {{ section.settings.sub_lh | divided_by: 10.0 }};
    --cats-sub-style:      {{ section.settings.sub_style }};
    --cats-sub-decoration: {{ section.settings.sub_decoration }};
    /* Card Label */
    --cats-lbl-font:       {{ section.settings.lbl_font }};
    --cats-lbl-size:       {{ section.settings.lbl_size }}px;
    --cats-lbl-weight:     {{ section.settings.lbl_weight }};
    --cats-lbl-transform:  {{ section.settings.lbl_transform }};
    --cats-lbl-ls:         {{ section.settings.lbl_ls | times: 0.1 }}px;
    --cats-lbl-lh:         {{ section.settings.lbl_lh | divided_by: 10.0 }};
    --cats-lbl-style:      {{ section.settings.lbl_style }};
    --cats-lbl-decoration: {{ section.settings.lbl_decoration }};
    /* Card Subtitle */
    --cats-csub-font:       {{ section.settings.csub_font }};
    --cats-csub-size:       {{ section.settings.csub_size }}px;
    --cats-csub-weight:     {{ section.settings.csub_weight }};
    --cats-csub-transform:  {{ section.settings.csub_transform }};
    --cats-csub-ls:         {{ section.settings.csub_ls | times: 0.1 }}px;
    --cats-csub-lh:         {{ section.settings.csub_lh | divided_by: 10.0 }};
    --cats-csub-style:      {{ section.settings.csub_style }};
    --cats-csub-decoration: {{ section.settings.csub_decoration }};
    /* Button */
    --cats-btn-font:       {{ section.settings.btn_font }};
    --cats-btn-size:       {{ section.settings.btn_size }}px;
    --cats-btn-weight:     {{ section.settings.btn_weight }};
    --cats-btn-transform:  {{ section.settings.btn_transform }};
    --cats-btn-ls:         {{ section.settings.btn_ls | times: 0.1 }}px;
    --cats-btn-lh:         {{ section.settings.btn_lh | divided_by: 10.0 }};
    --cats-btn-style:      {{ section.settings.btn_style }};
    --cats-btn-decoration: {{ section.settings.btn_decoration }};
    --cats-btn-pv:         {{ section.settings.btn_pv }}px;
    --cats-btn-ph:         {{ section.settings.btn_ph }}px;
    --cats-btn-radius:     {{ section.settings.btn_radius }}px;
    --cats-btn-bw:         {{ section.settings.btn_border_width }}px;
    --cats-btn-minw:       {{ section.settings.btn_min_width }}px;
    /* Layout */
    --cats-img-radius: {{ section.settings.image_radius }}px;
    --cats-card-gap:   {{ section.settings.card_gap }}px;
    --cats-pt:         {{ section.settings.section_pt }}px;
    --cats-pb:         {{ section.settings.section_pb }}px;
    /* Alignment & Container */
    --cats-align: {{ section.settings.content_align }};
    --cats-maxw:  {{ section.settings.content_max_width }}px;
    --cats-pl:    {{ section.settings.section_pl }}px;
    --cats-pr:    {{ section.settings.section_pr }}px;
    --cats-minh:  {{ section.settings.section_minh }}px;
    background-color: var(--cats-bg);
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --cats-eye-size:  {{ section.settings.eye_size_mobile }}px;
      --cats-head-size: {{ section.settings.head_size_mobile }}px;
      --cats-sub-size:  {{ section.settings.sub_size_mobile }}px;
      --cats-lbl-size:  {{ section.settings.lbl_size_mobile }}px;
      --cats-csub-size: {{ section.settings.csub_size_mobile }}px;
      --cats-btn-size:  {{ section.settings.btn_size_mobile }}px;
      --cats-pt: {{ section.settings.section_pt_mobile }}px;
      --cats-pb: {{ section.settings.section_pb_mobile }}px;
      --cats-pl: {{ section.settings.section_pl_mobile }}px;
      --cats-pr: {{ section.settings.section_pr_mobile }}px;
    }
  }
{%- endstyle -%}

<style>
  .gwmf-cats { width: 100%; }

  .gwmf-cats__inner {
    max-width: var(--cats-maxw);
    margin: 0 auto;
    padding: var(--cats-pt) var(--cats-pr) var(--cats-pb) var(--cats-pl);
    min-height: var(--cats-minh);
    text-align: var(--cats-align);
  }

  .gwmf-cats__eyebrow {
    font-family: var(--cats-eye-font);
    font-size: var(--cats-eye-size);
    font-weight: var(--cats-eye-weight);
    text-transform: var(--cats-eye-transform);
    letter-spacing: var(--cats-eye-ls);
    line-height: var(--cats-eye-lh);
    font-style: var(--cats-eye-style);
    text-decoration: var(--cats-eye-decoration);
    color: var(--cats-eyebrow);
    margin: 0 0 16px;
  }

  .gwmf-cats__heading {
    font-family: var(--cats-head-font);
    font-size: var(--cats-head-size);
    font-weight: var(--cats-head-weight);
    text-transform: var(--cats-head-transform);
    letter-spacing: var(--cats-head-ls);
    line-height: var(--cats-head-lh);
    font-style: var(--cats-head-style);
    text-decoration: var(--cats-head-decoration);
    color: var(--cats-heading);
    margin: 0 auto 18px;
    max-width: 760px;
  }

  .gwmf-cats__subtitle {
    font-family: var(--cats-sub-font);
    font-size: var(--cats-sub-size);
    font-weight: var(--cats-sub-weight);
    text-transform: var(--cats-sub-transform);
    letter-spacing: var(--cats-sub-ls);
    line-height: var(--cats-sub-lh);
    font-style: var(--cats-sub-style);
    text-decoration: var(--cats-sub-decoration);
    color: var(--cats-subtitle);
    margin: 0 0 52px;
  }

  .gwmf-cats__carousel-wrap { position: relative; }

  .gwmf-cats__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--cats-card-gap);
  }

  .gwmf-cats__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .gwmf-cats__img-wrap {
    width: 100%;
    border-radius: var(--cats-img-radius);
    overflow: hidden;
    aspect-ratio: 4/3;
    background: rgba(255,255,255,0.07);
  }

  .gwmf-cats__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .gwmf-cats__card:hover .gwmf-cats__img-wrap img { transform: scale(1.04); }

  .gwmf-cats__img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.3);
  }

  .gwmf-cats__label {
    font-family: var(--cats-lbl-font);
    font-size: var(--cats-lbl-size);
    font-weight: var(--cats-lbl-weight);
    text-transform: var(--cats-lbl-transform);
    letter-spacing: var(--cats-lbl-ls);
    line-height: var(--cats-lbl-lh);
    font-style: var(--cats-lbl-style);
    text-decoration: var(--cats-lbl-decoration);
    color: var(--cats-label);
  }

  .gwmf-cats__card-subtitle {
    font-family: var(--cats-csub-font);
    font-size: var(--cats-csub-size);
    font-weight: var(--cats-csub-weight);
    text-transform: var(--cats-csub-transform);
    letter-spacing: var(--cats-csub-ls);
    line-height: var(--cats-csub-lh);
    font-style: var(--cats-csub-style);
    text-decoration: var(--cats-csub-decoration);
    color: var(--cats-cardsub);
    margin: 0;
    text-align: center;
  }

  .gwmf-cats__card-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--cats-btn-pv) var(--cats-btn-ph);
    background: var(--cats-btn-bg);
    color: var(--cats-btn-text);
    font-family: var(--cats-btn-font);
    font-size: var(--cats-btn-size);
    font-weight: var(--cats-btn-weight);
    text-transform: var(--cats-btn-transform);
    letter-spacing: var(--cats-btn-ls);
    line-height: var(--cats-btn-lh);
    font-style: var(--cats-btn-style);
    text-decoration: var(--cats-btn-decoration);
    border-radius: var(--cats-btn-radius);
    border: var(--cats-btn-bw) solid var(--cats-btn-bc);
    min-width: var(--cats-btn-minw);
    transition: filter 0.2s, transform 0.15s;
    width: 100%;
    max-width: 320px;
  }

  .gwmf-cats__card-btn:hover { filter: brightness(0.85); transform: translateY(-2px); }

  .gwmf-cats__carousel-nav { display: none; }

  .gwmf-cats__eyebrow, .gwmf-cats__heading, .gwmf-cats__subtitle, .gwmf-cats__card {
    opacity: 0;
    transform: translateY(36px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .gwmf-cats.is-visible .gwmf-cats__eyebrow { opacity: 1; transform: translateY(0); transition-delay: 0s; }
  .gwmf-cats.is-visible .gwmf-cats__heading  { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
  .gwmf-cats.is-visible .gwmf-cats__subtitle { opacity: 1; transform: translateY(0); transition-delay: 0.18s; }
  .gwmf-cats.is-visible .gwmf-cats__card:nth-child(1) { opacity: 1; transform: translateY(0); transition-delay: 0.28s; }
  .gwmf-cats.is-visible .gwmf-cats__card:nth-child(2) { opacity: 1; transform: translateY(0); transition-delay: 0.42s; }
  .gwmf-cats.is-visible .gwmf-cats__card:nth-child(3) { opacity: 1; transform: translateY(0); transition-delay: 0.56s; }

  @media screen and (max-width: 989px) {
    .gwmf-cats__inner { padding: calc(var(--cats-pt)*0.72) calc(var(--cats-pr)*0.75) calc(var(--cats-pb)*0.75) calc(var(--cats-pl)*0.75); }
    .gwmf-cats__grid { gap: calc(var(--cats-card-gap)*0.71); }
  }

  @media screen and (max-width: 749px) {
    .gwmf-cats__inner { padding: var(--cats-pt) 0 var(--cats-pb); }
    .gwmf-cats__eyebrow, .gwmf-cats__heading, .gwmf-cats__subtitle { padding: 0 20px; }
    .gwmf-cats__subtitle { margin-bottom: 32px; }
    .gwmf-cats__card { opacity: 1 !important; transform: none !important; transition: none !important; }
    .gwmf-cats__carousel-wrap { overflow: hidden; }
    .gwmf-cats__grid { display: flex !important; flex-wrap: nowrap; gap: 0; padding: 0; transition: transform 0.36s cubic-bezier(0.25,0.46,0.45,0.94); will-change: transform; }
    .gwmf-cats__card { flex: 0 0 100%; width: 100%; padding: 0 20px; box-sizing: border-box; }
    .gwmf-cats__card-btn { max-width: 100%; padding: 14px 20px; }
    .gwmf-cats__carousel-nav { display: flex; align-items: center; justify-content: center; gap: 16px; margin-top: 24px; padding: 0 20px; }
    .gwmf-cats__carousel-btn { width: 40px; height: 40px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.25); background: rgba(255,255,255,0.1); color: var(--cats-label); display: flex; align-items: center; justify-content: center; cursor: pointer; flex-shrink: 0; transition: background 0.2s; }
    .gwmf-cats__carousel-btn svg { width: 20px; height: 20px; display: block; stroke: currentColor; fill: none; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; }
    .gwmf-cats__carousel-dots { display: flex; gap: 8px; align-items: center; }
    .gwmf-cats__dot { width: 8px; height: 8px; border-radius: 50%; border: none; background: rgba(255,255,255,0.3); cursor: pointer; padding: 0; transition: background 0.2s, transform 0.2s; }
    .gwmf-cats__dot.is-active { background: var(--cats-btn-bg); transform: scale(1.4); }
  }

  @media screen and (max-width: 480px) {
    .gwmf-cats__inner { padding: var(--cats-pt) 0 var(--cats-pb); }
    .gwmf-cats__card { padding: 0 16px; }
  }
</style>

<section class="gwmf-cats" id="shopify-section-{{ section.id }}">
  <div class="gwmf-cats__inner">
    {%- if section.settings.eyebrow != blank -%}<p class="gwmf-cats__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="gwmf-cats__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.subtitle != blank -%}<p class="gwmf-cats__subtitle">{{ section.settings.subtitle }}</p>{%- endif -%}

    <div class="gwmf-cats__carousel-wrap">
      <div class="gwmf-cats__grid" id="cats-track-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="gwmf-cats__card" {{ block.shopify_attributes }}>
            <div class="gwmf-cats__img-wrap">
              {%- if block.settings.image != blank -%}
                {%- assign img_alt = block.settings.image.alt | default: block.settings.label | escape -%}
                {{ block.settings.image | image_url: width: 800 | image_tag: alt: img_alt, loading: 'lazy', widths: '400, 600, 800' }}
              {%- else -%}
                <div class="gwmf-cats__img-placeholder"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg></div>
              {%- endif -%}
            </div>
            {%- if block.settings.label != blank -%}<span class="gwmf-cats__label">{{ block.settings.label }}</span>{%- endif -%}
            {%- if block.settings.subtitle != blank -%}<p class="gwmf-cats__card-subtitle">{{ block.settings.subtitle }}</p>{%- endif -%}
            {%- if block.settings.btn_label != blank -%}
              <a href="{{ block.settings.btn_link }}" class="gwmf-cats__card-btn">{{ block.settings.btn_label }}</a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      <div class="gwmf-cats__carousel-nav" id="cats-nav-{{ section.id }}">
        <button class="gwmf-cats__carousel-btn" id="cats-prev-{{ section.id }}" aria-label="Previous slide"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg></button>
        <div class="gwmf-cats__carousel-dots" id="cats-dots-{{ section.id }}"></div>
        <button class="gwmf-cats__carousel-btn" id="cats-next-{{ section.id }}" aria-label="Next slide"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></button>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var sectionId = '{{ section.id }}';
    var sec = document.querySelector('#shopify-section-' + sectionId + ' .gwmf-cats');
    var track = document.getElementById('cats-track-' + sectionId);
    var dotsWrap = document.getElementById('cats-dots-' + sectionId);
    var prevBtn = document.getElementById('cats-prev-' + sectionId);
    var nextBtn = document.getElementById('cats-next-' + sectionId);
    if (!sec || !track) return;
    var io = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) { sec.classList.add('is-visible'); io.disconnect(); }
    }, { threshold: 0.1 });
    io.observe(sec);
    var cards = Array.prototype.slice.call(track.querySelectorAll('.gwmf-cats__card'));
    if (cards.length === 0) return;
    var currentIndex = 0;
    var mq = window.matchMedia('(max-width: 749px)');
    cards.forEach(function (_, i) {
      var dot = document.createElement('button');
      dot.className = 'gwmf-cats__dot' + (i === 0 ? ' is-active' : '');
      dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
      dot.addEventListener('click', function () { goTo(i); });
      dotsWrap.appendChild(dot);
    });
    function updateDots(idx) {
      dotsWrap.querySelectorAll('.gwmf-cats__dot').forEach(function (d, i) { d.classList.toggle('is-active', i === idx); });
    }
    function goTo(idx) {
      if (!mq.matches) return;
      idx = Math.max(0, Math.min(idx, cards.length - 1));
      currentIndex = idx;
      track.style.transform = 'translateX(-' + (idx * 100) + '%)';
      updateDots(idx);
    }
    prevBtn && prevBtn.addEventListener('click', function () { goTo(currentIndex - 1); });
    nextBtn && nextBtn.addEventListener('click', function () { goTo(currentIndex + 1); });
    var touchStartX = 0;
    track.addEventListener('touchstart', function (e) { touchStartX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', function (e) {
      var diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) goTo(diff > 0 ? currentIndex + 1 : currentIndex - 1);
    }, { passive: true });
    window.addEventListener('resize', function () {
      if (!mq.matches) { track.style.transform = ''; currentIndex = 0; updateDots(0); }
    });
  })();
</script>

{% schema %}
{
  "name": "Category Showcase",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0a1a30" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "#7aa8d8" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#4a9fe0" },
    { "type": "color", "id": "subtitle_color", "label": "Subtitle color", "default": "#8eacc8" },
    { "type": "color", "id": "label_color", "label": "Card label color", "default": "#000000" },
    { "type": "color", "id": "card_subtitle_color", "label": "Card subtitle color", "default": "#667085" },
    { "type": "color", "id": "btn_bg_color", "label": "Button background", "default": "#0056a3" },
    { "type": "color", "id": "btn_text_color", "label": "Button text color", "default": "#ffffff" },
    { "type": "color", "id": "btn_border_color", "label": "Button border color", "default": "#0056a3" },

    { "type": "header", "content": "Typography — Eyebrow" },
    { "type": "select", "id": "eye_font", "label": "Font family", "options": [{ "value": "Outfit, sans-serif", "label": "Outfit (Body)" }, { "value": "Dimbo, Outfit, sans-serif", "label": "Dimbo (Display)" }], "default": "Outfit, sans-serif" },
    { "type": "range", "id": "eye_size", "label": "Size (px)", "min": 10, "max": 100, "step": 1, "default": 14 },
    { "type": "select", "id": "eye_weight", "label": "Weight", "options": [{ "value": "400", "label": "400 — Regular" }, { "value": "500", "label": "500 — Medium" }, { "value": "600", "label": "600 — Semi Bold" }, { "value": "700", "label": "700 — Bold" }, { "value": "800", "label": "800 — Extra Bold" }], "default": "600" },
    { "type": "select", "id": "eye_transform", "label": "Text transform", "options": [{ "value": "none", "label": "None" }, { "value": "uppercase", "label": "UPPERCASE" }, { "value": "lowercase", "label": "lowercase" }, { "value": "capitalize", "label": "Capitalize" }], "default": "uppercase" },
    { "type": "range", "id": "eye_ls", "label": "Letter spacing (×0.1px)", "min": -20, "max": 200, "step": 5, "default": 25 },
    { "type": "range", "id": "eye_lh", "label": "Line height (÷10)", "min": 8, "max": 50, "step": 1, "default": 14 },
    { "type": "select", "id": "eye_style", "label": "Font style", "options": [{ "value": "normal", "label": "Normal" }, { "value": "italic", "label": "Italic" }], "default": "normal" },
    { "type": "select", "id": "eye_decoration", "label": "Text decoration", "options": [{ "value": "none", "label": "None" }, { "value": "underline", "label": "Underline" }, { "value": "line-through", "label": "Line-through" }], "default": "none" },

    { "type": "header", "content": "Typography — Section Heading" },
    { "type": "select", "id": "head_font", "label": "Font family", "options": [{ "value": "Dimbo, Outfit, sans-serif", "label": "Dimbo (Display)" }, { "value": "Outfit, sans-serif", "label": "Outfit (Body)" }], "default": "Dimbo, Outfit, sans-serif" },
    { "type": "range", "id": "head_size", "label": "Size — desktop (px)", "min": 24, "max": 224, "step": 2, "default": 62 },
    { "type": "select", "id": "head_weight", "label": "Weight", "options": [{ "value": "400", "label": "400 — Regular" }, { "value": "500", "label": "500 — Medium" }, { "value": "600", "label": "600 — Semi Bold" }, { "value": "700", "label": "700 — Bold" }, { "value": "800", "label": "800 — Extra Bold" }, { "value": "900", "label": "900 — Black" }], "default": "800" },
    { "type": "select", "id": "head_transform", "label": "Text transform", "options": [{ "value": "none", "label": "None" }, { "value": "uppercase", "label": "UPPERCASE" }, { "value": "lowercase", "label": "lowercase" }, { "value": "capitalize", "label": "Capitalize" }], "default": "none" },
